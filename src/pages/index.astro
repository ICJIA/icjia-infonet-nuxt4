---
// astro/src/pages/index.astro
//
// Home page — static parts only.
// Dynamic widgets (HomeBarGraph, HomeBoxes, HomePosts, HomeEvents,
// InfoNet Research carousel) land in Phase 5b.
//
// Static content ported from:
//   - Legacy app/pages/index.vue (badge, INFONET title, tagline, body, partners link)
//   - Strapi "index" page body (slug: 'index') for the description paragraph
//
// Font: Raleway 900 for the large INFONET title (same weight / color as nav).
// Color: #0d4270 (nav brand color, confirmed in AppNav.astro / legacy CSS).
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomeBoxes from '~/components/HomeBoxes.astro';
import HomeBarGraph from '~/components/HomeBarGraph.astro';
import HomePosts from '~/components/HomePosts.astro';
import HomeFaqs from '~/components/HomeFaqs.astro';
import { siteConfig } from '~/lib/siteConfig';

const description =
  'InfoNet is a web-based data collection and reporting system used by victim service providers ' +
  'in Illinois to facilitate standardized statewide data collection.';

// Home gets combined WebSite + GovernmentOrganization JSON-LD so AI crawlers
// have explicit publisher identity + searchAction surface. BaseLayout emits
// each array entry as its own <script type="application/ld+json"> block so
// each carries `@type` at the root (assessors look there).
// No dateModified: stamping the build time claimed the page changed on every
// deploy, which teaches crawlers to distrust the site's freshness signals.
const homeJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'InfoNet',
    alternateName: 'ICJIA InfoNet',
    url: 'https://infonet.icjia.illinois.gov',
    description,
    inLanguage: 'en-US',
    datePublished: siteConfig.siteLaunchDate,
    publisher: { '@id': 'https://icjia.illinois.gov#icjia' },
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: 'https://infonet.icjia.illinois.gov/search/?q={search_term_string}',
      },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'GovernmentOrganization',
    '@id': 'https://icjia.illinois.gov#icjia',
    name: 'Illinois Criminal Justice Information Authority',
    alternateName: 'ICJIA',
    url: 'https://icjia.illinois.gov',
    logo: 'https://infonet.icjia.illinois.gov/icjia-logo.png',
    parentOrganization: { '@type': 'GovernmentOrganization', name: 'State of Illinois' },
    sameAs: [
      'https://www.facebook.com/ICJIA/',
      'https://www.youtube.com/c/illinoiscriminaljusticeinformationauthority',
      'https://www.instagram.com/icjia_illinois/',
      'https://www.linkedin.com/company/icjia/',
    ],
  },
];
---
<BaseLayout title="Home" description={description} jsonLd={homeJsonLd}>
  <!-- Hero + chart row: full-bleed gray, 2-col grid at ≥960 px (Vuetify md).
       Tailwind utilities mirror legacy Vuetify <v-row><v-col cols=12 md=6>.
       Arbitrary breakpoint min-[960px]: matches legacy Vuetify exactly
       (Tailwind default md=768px would switch too early). -->
  <section class="w-full bg-[#f2f2f2] px-8 pt-8 pb-12">
    <div class="grid grid-cols-1 min-[960px]:grid-cols-2 gap-8 items-start">
      <div class="home-hero-inner">
          <div class="home-badge">
            Illinois Criminal Justice Information Authority
          </div>

          <h1 class="infonet-title">INFONET</h1>

          <p class="infonet-tagline">
            Illinois&rsquo; victim service data resource for over 25 years
          </p>

          <div class="home-lead">
            <p>
              InfoNet is a web-based data collection and reporting system used by
              victim service providers in Illinois. The system is nationally
              recognized for facilitating standardized data collection and reporting
              at the statewide level. Initial development of InfoNet began in the
              mid-90s as a collaborative effort between the Illinois Criminal Justice
              Information Authority, the Illinois Coalition Against Sexual Assault,
              and the Illinois Coalition Against Domestic Violence. Since then,
              InfoNet has grown to include partnerships with the Illinois Department
              of Human Services and the Chicago Department of Family &amp; Support
              Services.
            </p>
          </div>

          <p class="home-partners-link">
            <a href="/partners/">List of Partners&nbsp;&raquo;</a>
          </p>
        </div>

        <HomeBarGraph />
    </div>
  </section>

  <!-- HomeBoxes: full-bleed dark blue, no inner container constraint -->
  <HomeBoxes />

  <!-- News + FAQs row: edge-to-edge gray, 2-col at ≥960 px (Vuetify md).
       Tailwind utilities mirror legacy <v-row><v-col cols=12 md=6>. -->
  <section class="w-full bg-[#f2f2f2]">
    <div class="grid grid-cols-1 min-[960px]:grid-cols-2">
      <HomePosts />
      <HomeFaqs />
    </div>
  </section>
</BaseLayout>

<style>
  /* Raleway is self-hosted via @fontsource (global.css) — the old Google
     Fonts @import here was redundant, render-blocking, and leaked visitor
     IPs to Google; it was also the only thing keeping fonts.googleapis.com
     in the CSP. */

  /* Hero typography only — section/grid/column layout is now driven by
     Tailwind utilities inline (grid-cols-1 md:grid-cols-2 etc.) so the
     responsive behaviour mirrors the legacy Vuetify <v-row><v-col>. */
  .home-hero-inner {
    max-width: 100%;
  }

  /* Match legacy rendered dimensions (measured 2026-05-26):
     badge: font-size 12.8px (0.8em × 16px root), margin-top 35px
     h1:    font-size 75px, line-height 1.5, color #0b3a62, margin-top 8px
     h2:    font-size 18px, line-height 1.25, margin -10px 0 32px */
  .home-badge {
    display: inline-block;
    font-weight: 900;
    font-size: 0.8em;          /* 12.8px at 16px root */
    color: #fff;
    background: #0d4474;
    padding: 5px 10px;
    border-radius: 3px;
    margin-top: 35px;
    margin-bottom: 5px;
    line-height: 1.4;
  }

  .infonet-title {
    font-family: 'Raleway', 'Arial Black', sans-serif;
    font-weight: 900;
    font-size: 75px;            /* legacy renders at 75px */
    line-height: 1.5;            /* legacy 112.5px / 75px = 1.5 */
    color: #0b3a62;              /* legacy color (slightly different blue) */
    margin: 8px 0 0;
    padding: 0;
    border: none;
  }

  .infonet-tagline {
    font-size: 18px;            /* matches legacy exactly */
    font-weight: 400;
    line-height: 1.25;           /* legacy 22.5px / 18px = 1.25 */
    color: #222;
    margin-top: -5px;
    margin-bottom: 2rem;
    padding-left: 2px;
    border: none;
  }

  .home-lead {
    font-size: 1rem;
    line-height: 1.65;
    color: #333;
  }

  .home-lead p {
    margin: 0 0 1rem;
  }

  .home-partners-link {
    margin-top: 1.5rem;
    text-align: center;
  }

  .home-partners-link a {
    font-weight: 700;
    color: #000;
    text-decoration: none;
    font-size: 0.95rem;
    text-transform: uppercase;
  }

  .home-partners-link a:hover,
  .home-partners-link a:focus {
    text-decoration: underline;
    color: #0d4270;
  }

</style>
