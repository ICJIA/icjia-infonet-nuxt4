---
// astro/src/pages/debug/[...slug].astro
//
// Minimal debug page — excluded from sitemap by astro.config.ts filter.
// Legacy: app/pages/debug.vue had two external link samples.
// This version adds build-time env info for diagnostics.
import BaseLayout from '~/layouts/BaseLayout.astro';

// Dev/preview tool only. Dynamic route so getStaticPaths can emit NOTHING in
// production builds: prod /debug/ falls through to the 404 page and build
// internals aren't advertised at a guessable URL. (The previous
// `Astro.redirect('/404/')` published Astro's meta-refresh stub, which failed
// WCAG 2.2.1 — 2s timed refresh — and 3.1.1 — bare <html> without lang.)
export function getStaticPaths() {
  return import.meta.env.PROD ? [] : [{ params: { slug: undefined } }];
}

const buildEnv = {
  site: import.meta.env.SITE ?? '(not set)',
  mode: import.meta.env.MODE,
  prod: import.meta.env.PROD,
  dev: import.meta.env.DEV,
  strapiBase: import.meta.env.PUBLIC_STRAPI_BASE ?? '(not set)',
};
---
<BaseLayout title="Debug" breadcrumbTitle="Debug" noindex={true}>
  <h1>Debug</h1>
  <p style="font-size: 0.875rem; color: var(--color-ink-muted);">Build-time info (excluded from sitemap).</p>

  <section style="margin-top: 24px;">
    <h2>External link test</h2>
    <p>
      <a href="https://www.amazon.com" target="_blank" rel="noopener noreferrer">Sample external link (amazon)</a>
      &nbsp;|&nbsp;
      <a href="https://www.cnn.com" target="_blank" rel="noopener noreferrer">Sample external link (cnn)</a>
    </p>
  </section>

  <section style="margin-top: 24px;">
    <h2>Build environment</h2>
    <pre style="background:var(--color-surface-soft);border:1px solid var(--color-border-mid);border-radius:4px;padding:12px;font-size:0.75rem;overflow-x:auto;">{JSON.stringify(buildEnv, null, 2)}</pre>
  </section>
</BaseLayout>
