---
// astro/src/pages/debug.astro
//
// Minimal debug page — excluded from sitemap by astro.config.ts filter.
// Legacy: app/pages/debug.vue had two external link samples.
// This version adds build-time env info for diagnostics.
import BaseLayout from '~/layouts/BaseLayout.astro';

const buildEnv = {
  site: import.meta.env.SITE ?? '(not set)',
  mode: import.meta.env.MODE,
  prod: import.meta.env.PROD,
  dev: import.meta.env.DEV,
  strapiBase: import.meta.env.PUBLIC_STRAPI_BASE ?? '(not set)',
};
---
<BaseLayout title="Debug" breadcrumbTitle="Debug" noindex={true}>
  <h1>Debug</h1>
  <p style="font-size: 0.875rem; color: #666;">Build-time info (excluded from sitemap).</p>

  <section style="margin-top: 24px;">
    <h2>External link test</h2>
    <p>
      <a href="https://www.amazon.com" target="_blank" rel="noopener noreferrer">Sample external link (amazon)</a>
      &nbsp;|&nbsp;
      <a href="https://www.cnn.com" target="_blank" rel="noopener noreferrer">Sample external link (cnn)</a>
    </p>
  </section>

  <section style="margin-top: 24px;">
    <h2>Build environment</h2>
    <pre style="background:#f5f5f5;border:1px solid #ddd;border-radius:4px;padding:12px;font-size:0.75rem;overflow-x:auto;">{JSON.stringify(buildEnv, null, 2)}</pre>
  </section>
</BaseLayout>
