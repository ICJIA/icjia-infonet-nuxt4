---
// astro/src/pages/faqs/index.astro
//
// 135 FAQs from Strapi, grouped by agency field and rendered as native
// <details> accordions in sections matching the legacy /faqs/ layout:
//   - Downloads section (hardcoded DOCX URLs from legacy content/faqs.md)
//   - "General FAQs"         — agency: null / "general" / ""
//   - "Domestic Violence (DV) FAQs" — agency: "dv"
//   - "Sexual Assault (SA) FAQs"    — agency: "sa"
//   - "Children's Advocacy Center (CAC) FAQs" — agency: "cac" (if any)
// Each h2 has an id for Toc linking. Toc sidebar is in a 2-col layout
// matching [...slug].astro with showTableOfContents pages.
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHeader from '~/components/PageHeader.astro';
import Toc from '~/components/Toc.astro';
import { strapiFetch, assertNoTruncation } from '~/lib/strapi';
import { QUERY_FAQ_LIST } from '~/lib/queries';
import { FaqListResponseSchema } from '~/lib/schemas';
import { renderMarkdown } from '~/lib/markdown';
import type { Heading } from '~/lib/markdown';
import { gitLastModifiedISO } from '~/lib/gitDates';

const raw = await strapiFetch(QUERY_FAQ_LIST);
const parsed = FaqListResponseSchema.parse(raw);
assertNoTruncation('faqs', parsed.faqs.data.length, parsed.faqs.meta?.pagination?.total);
const allFaqs = [...parsed.faqs.data].sort((a, b) => {
  const ar = a.attributes.ranking ?? 9999;
  const br = b.attributes.ranking ?? 9999;
  if (ar !== br) return ar - br;
  const da = a.attributes.createdAt ?? '';
  const db = b.attributes.createdAt ?? '';
  return da < db ? -1 : da > db ? 1 : 0;
});

// Group by agency — null/empty/"general" → "general"
function normaliseAgency(agency: string | null | undefined): string {
  const a = (agency ?? '').toLowerCase().trim();
  return a === '' || a === 'general' ? 'general' : a;
}

const groups: Record<string, typeof allFaqs> = {};
for (const faq of allFaqs) {
  const key = normaliseAgency(faq.attributes.agency);
  if (!groups[key]) groups[key] = [];
  groups[key].push(faq);
}

const sectionDefs = [
  { key: 'general', id: 'general-faqs', label: 'General FAQs' },
  { key: 'dv', id: 'dv-faqs', label: 'Domestic Violence (DV) FAQs' },
  { key: 'sa', id: 'sa-faqs', label: 'Sexual Assault (SA) FAQs' },
  { key: 'cac', id: 'cac-faqs', label: "Children's Advocacy Center (CAC) FAQs" },
];

// Build TOC headings manually — downloads + each non-empty FAQ section.
// Matches the shape expected by Toc.astro (level, text, id).
const tocHeadings: Heading[] = [
  { level: 2, text: 'Downloads', id: 'downloads' },
  ...sectionDefs
    .filter((s) => (groups[s.key] ?? []).length > 0)
    .map((s) => ({ level: 2, text: s.label, id: s.id })),
];
---
<BaseLayout title="FAQs" breadcrumbTitle="FAQs" dateModified={gitLastModifiedISO('src/pages/faqs/index.astro')}>
  <PageHeader title="Frequently Asked Questions" />

  <div class="faqs-layout page-container">
    <div class="faqs-body">

      <!-- Downloads -------------------------------------------------------- -->
      <section aria-labelledby="downloads">
        <h2 id="downloads" class="section-heading">Downloads</h2>
        <p class="section-intro">Printer-friendly FAQs:</p>
        <ul class="downloads-list">
          <li>
            <a
              href="https://infonet.icjia-api.cloud/uploads/3_3_1_DV_INFONET_Frequently_Asked_Questions_7_7_23_5b58b1a47b.docx"
              target="_blank"
              rel="noopener noreferrer"
            >
              Domestic Violence (DV)
            </a>
          </li>
          <li>
            <a
              href="https://infonet.icjia-api.cloud/uploads/3_3_2_SA_INFONET_Frequently_Asked_Questions_7_7_23_7c737ee0ff.docx"
              target="_blank"
              rel="noopener noreferrer"
            >
              Sexual Assault (SA)
            </a>
          </li>
        </ul>
      </section>

      <!-- FAQ sections per agency ----------------------------------------- -->
      {sectionDefs.map(({ key, id, label }) => {
        const faqs = groups[key] ?? [];
        if (faqs.length === 0) return null;
        return (
          <section aria-labelledby={id} style="margin-top: 2rem;">
            <h2 id={id} class="section-heading">{label}</h2>
            <p class="section-count">{faqs.length} question{faqs.length !== 1 ? 's' : ''}</p>
            <div>
              {faqs.map((f) => {
                const { html } = renderMarkdown(f.attributes.answer);
                const slug = f.attributes.slug;
                return (
                  <details class="faq-item">
                    {/* The question is an h3 WITH an id: Pagefind builds its
                        search sub-results from headings that carry ids, so
                        each FAQ becomes its own search result linking to
                        /faqs/#faq-<slug> (the page script below opens the
                        accordion on arrival). Heading content inside
                        <summary> is spec-permitted; Tailwind preflight
                        resets h3 styling so it inherits the summary look. */}
                    <summary class="faq-summary">
                      <h3 class="faq-question" id={slug ? `faq-${slug}` : undefined}>
                        {f.attributes.question ?? '(untitled)'}
                      </h3>
                      <svg aria-hidden="true" focusable="false" class="faq-chevron" viewBox="0 0 16 16" width="20" height="20"><path fill="currentColor" d="M2 4l6 7 6-7z"/></svg>
                    </summary>
                    <div class="markdown-body faq-body" set:html={html} />
                  </details>
                );
              })}
            </div>
          </section>
        );
      })}

    </div>
  </div>
</BaseLayout>

<script>
  // Deep-link support: /faqs/#faq-<slug> (e.g. from Pagefind search
  // sub-results). The browser scrolls to the <details> anchor, but a closed
  // accordion would leave the answer hidden — open it, then re-scroll once
  // layout has settled so the question lands below the fixed nav.
  function openFaqFromHash(): void {
    const id = decodeURIComponent(window.location.hash.slice(1));
    if (!id) return;
    const target = document.getElementById(id);
    if (!target) return;
    const details =
      target instanceof HTMLDetailsElement ? target : target.closest('details');
    if (!(details instanceof HTMLDetailsElement)) return;
    details.open = true;
    requestAnimationFrame(() => target.scrollIntoView({ block: 'start' }));
  }
  openFaqFromHash();
  window.addEventListener('hashchange', openFaqFromHash);
</script>

<style>
  .faqs-layout {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    max-width: 1100px;
  }

  .faqs-body {
    flex: 1 1 0;
    min-width: 0;
  }

  .faqs-toc-sidebar {
    flex: 0 0 260px;
    position: sticky;
    top: 170px;
  }

  @media (max-width: 768px) {
    .faqs-layout {
      flex-direction: column;
    }

    .faqs-toc-sidebar {
      flex: none;
      position: static;
      width: 100%;
      order: -1;
    }
  }

  .section-heading {
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--color-brand);
    margin: 0 0 0.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .section-intro,
  .section-count {
    color: var(--color-ink-soft); /* 7.46:1 — 1.4.6 (AAA) needs 7:1 */
    font-size: 0.875rem;
    margin: 0 0 12px;
  }

  .downloads-list {
    margin: 0 0 8px 1.25rem;
    padding: 0;
  }

  .downloads-list li {
    margin-bottom: 4px;
  }

  .downloads-list a {
    color: var(--color-brand);
    font-weight: 700;
    /* 2.5.5 (AAA): solo link per list item — no inline exemption */
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    min-width: 44px;
  }

  .faq-item {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    margin-bottom: 8px;
  }

  .faq-question {
    /* Inherit the summary's typography (Tailwind preflight already strips
       default h3 sizing); the heading exists for Pagefind sub-results and
       document outline, not for visual hierarchy. */
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    margin: 0;
    padding: 0;
    border: none;
    /* Deep-link anchor landing position: clear the 80px fixed nav +
       breadcrumb bar when the browser scrolls to #faq-<slug>. */
    scroll-margin-top: 130px;
  }

  .faq-summary {
    /* Explicit white background so axe can resolve the ▾ chevron's
       contrast against a known colour (was flagged "needs review"
       because nested transparent backgrounds aren't sampled). */
    background: var(--color-surface);
    padding: 12px 16px;
    cursor: pointer;
    font-weight: 700;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-chevron {
    color: var(--color-brand);
    flex-shrink: 0;
    margin-left: 8px;
    display: block;
  }

  .faq-body {
    padding: 12px 16px 16px;
  }
</style>
