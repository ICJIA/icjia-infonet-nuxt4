---
// astro/src/pages/faqs/index.astro
//
// 135 FAQs from Strapi, rendered as native <details> accordions.
// Sorted by ranking (ascending, nulls last) then createdAt.
// renderMarkdown() is used for answer bodies — CMS authors may use markdown
// in answer fields (confirmed in Phase 3 smoke test).
import BaseLayout from '~/layouts/BaseLayout.astro';
import { strapiFetch } from '~/lib/strapi';
import { QUERY_FAQ_LIST } from '~/lib/queries';
import { FaqListResponseSchema } from '~/lib/schemas';
import { renderMarkdown } from '~/lib/markdown';

const raw = await strapiFetch(QUERY_FAQ_LIST);
const parsed = FaqListResponseSchema.parse(raw);
const faqs = [...parsed.faqs.data].sort((a, b) => {
  const ar = a.attributes.ranking ?? 9999;
  const br = b.attributes.ranking ?? 9999;
  if (ar !== br) return ar - br;
  const da = a.attributes.createdAt ?? '';
  const db = b.attributes.createdAt ?? '';
  return da < db ? -1 : da > db ? 1 : 0;
});
---
<BaseLayout title="FAQs" breadcrumbTitle="FAQs">
  <h1>Frequently Asked Questions</h1>
  <p style="color:#666;font-size:0.875rem;margin-bottom:24px;">
    {faqs.length} questions
  </p>

  <div style="max-width:800px;">
    {faqs.map((f) => {
      const { html } = renderMarkdown(f.attributes.answer);
      return (
        <details style="border:1px solid #e0e0e0;border-radius:4px;margin-bottom:8px;">
          <summary style="padding:12px 16px;cursor:pointer;font-weight:700;list-style:none;display:flex;justify-content:space-between;align-items:center;">
            <span>{f.attributes.question ?? '(untitled)'}</span>
            <span aria-hidden="true" style="font-size:1.25rem;color:#0d4270;">&#x25BE;</span>
          </summary>
          <div class="markdown-body" style="padding:12px 16px 16px;" set:html={html} />
        </details>
      );
    })}
  </div>
</BaseLayout>
