---
// astro/src/pages/contact.astro
//
// Port of app/pages/contact.vue (308 lines, Vuetify-free).
//
// Form submission wires:
//   POST https://infonet.icjia-api.cloud/api/forms  (DB insert, best-effort archive)
//   POST https://mail.icjia.cloud/internet/infonet   (email — the POST that matters)
// Both endpoints are called via Alpine.js fetch() on submit, so BOTH must be
// allowed by the CSP `connect-src` directive in netlify.toml (fetch() is not
// governed by form-action). Success is only shown when the email POST returns
// ok; otherwise a visible error banner asks the user to retry.
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHeader from '~/components/PageHeader.astro';
import { gitLastModifiedISO } from '~/lib/gitDates';
---
<BaseLayout title="Contact" breadcrumbTitle="Contact" dateModified={gitLastModifiedISO('src/pages/contact.astro')}>
  <div class="page-container">
  <PageHeader title="Contact InfoNet" />

  <div
    x-data="{
      subject: '',
      firstname: '',
      lastname: '',
      email: '',
      phone: '',
      message: '',
      submitted: false,
      submitting: false,
      failed: false,
      errors: {},
      init() {
        const s = new URLSearchParams(window.location.search).get('subject');
        if (s) this.subject = s.slice(0, 200);
      },
      validate() {
        this.errors = {};
        if (!this.subject.trim()) this.errors.subject = 'Subject is required';
        if (!this.firstname.trim()) this.errors.firstname = 'First name is required';
        if (!this.lastname.trim()) this.errors.lastname = 'Last name is required';
        if (!this.email.trim()) this.errors.email = 'Email is required';
        else if (!/^[^@]+@[^@]+\.[^@]+$/.test(this.email)) this.errors.email = 'Email must be valid';
        if (!this.phone.trim()) this.errors.phone = 'Phone number is required';
        if (!this.message.trim()) this.errors.message = 'Message is required';
        return Object.keys(this.errors).length === 0;
      },
      sanitize(str) {
        return str.replace(/[^a-z0-9áéíóúñü .,_-]/gim, '').trim();
      },
      sanitizeEmail(str) {
        return str.replace(/[^a-z0-9@+._-]/gim, '').trim();
      },
      async submitForm() {
        if (!this.validate()) return;
        this.submitting = true;
        this.failed = false;
        const form = {
          type: 'InfoNet Contact',
          subject: this.sanitize(this.subject),
          firstname: this.sanitize(this.firstname),
          lastname: this.sanitize(this.lastname),
          email: this.sanitizeEmail(this.email),
          phone: this.sanitize(this.phone),
          message: this.sanitize(this.message),
        };
        try {
          await fetch('https://infonet.icjia-api.cloud/api/forms', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ data: { type: form.type, email: form.email, subject: form.subject, form } }),
          });
        } catch(e) { console.error('db insert failure', e); }
        try {
          const res = await fetch('https://mail.icjia.cloud/internet/infonet', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(form),
          });
          if (!res.ok) throw new Error('mail endpoint returned ' + res.status);
          this.submitted = true;
        } catch(e) {
          console.error('email failure', e);
          this.failed = true;
        }
        this.submitting = false;
      },
      clearForm() {
        this.subject = ''; this.firstname = ''; this.lastname = '';
        this.email = ''; this.phone = ''; this.message = '';
        this.errors = {}; this.submitted = false; this.failed = false;
      }
    }"
    style="max-width: 720px; margin: 0 auto;"
  >
    <form
      x-show="!submitted"
      :inert="submitted"
      @submit.prevent="submitForm"
      novalidate
      class="contact-form"
    >
      <!-- Subject -->
      <div class="field-group">
        <label for="contact-subject" class="field-label">Subject</label>
        <input
          id="contact-subject"
          type="text"
          x-model="subject"
          autocomplete="off"
          required
          aria-required="true"
          :aria-describedby="errors.subject ? 'err-subject' : null"
          class="field-input"
        />
        <span id="err-subject" x-show="errors.subject" x-text="errors.subject" class="field-error" role="alert"></span>
      </div>

      <!-- First / Last name row -->
      <div class="field-row grid grid-cols-1 min-[600px]:grid-cols-2 gap-4">
        <div class="field-group">
          <label for="contact-firstname" class="field-label">First Name</label>
          <input
            id="contact-firstname"
            type="text"
            x-model="firstname"
            autocomplete="given-name"
            required
            aria-required="true"
            :aria-describedby="errors.firstname ? 'err-firstname' : null"
            class="field-input"
          />
          <span id="err-firstname" x-show="errors.firstname" x-text="errors.firstname" class="field-error" role="alert"></span>
        </div>
        <div class="field-group">
          <label for="contact-lastname" class="field-label">Last Name</label>
          <input
            id="contact-lastname"
            type="text"
            x-model="lastname"
            autocomplete="family-name"
            required
            aria-required="true"
            :aria-describedby="errors.lastname ? 'err-lastname' : null"
            class="field-input"
          />
          <span id="err-lastname" x-show="errors.lastname" x-text="errors.lastname" class="field-error" role="alert"></span>
        </div>
      </div>

      <!-- Email / Phone row -->
      <div class="field-row grid grid-cols-1 min-[600px]:grid-cols-2 gap-4">
        <div class="field-group">
          <label for="contact-email" class="field-label">Email</label>
          <input
            id="contact-email"
            type="email"
            x-model="email"
            autocomplete="email"
            required
            aria-required="true"
            :aria-describedby="errors.email ? 'err-email' : null"
            class="field-input"
          />
          <span id="err-email" x-show="errors.email" x-text="errors.email" class="field-error" role="alert"></span>
        </div>
        <div class="field-group">
          <label for="contact-phone" class="field-label">Phone Number</label>
          <input
            id="contact-phone"
            type="tel"
            x-model="phone"
            autocomplete="tel"
            required
            aria-required="true"
            :aria-describedby="errors.phone ? 'err-phone' : null"
            class="field-input"
          />
          <span id="err-phone" x-show="errors.phone" x-text="errors.phone" class="field-error" role="alert"></span>
        </div>
      </div>

      <!-- Message -->
      <div class="field-group" style="margin-bottom: 24px;">
        <label for="contact-message" class="field-label">Message</label>
        <textarea
          id="contact-message"
          x-model="message"
          required
          aria-required="true"
          rows="6"
          :aria-describedby="errors.message ? 'err-message' : null"
          class="field-input"
          style="resize:vertical;"
        ></textarea>
        <span id="err-message" x-show="errors.message" x-text="errors.message" class="field-error" role="alert"></span>
      </div>

      <!-- Failure state: shown when the email POST does not return ok. -->
      <div
        x-cloak
        x-show="failed"
        role="alert"
        class="form-error-banner"
      >
        Sorry &mdash; your message could not be submitted. Please try again in a few minutes.
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-submit" :disabled="submitting" x-text="submitting ? 'Submitting…' : 'Submit'">Submit</button>
        <button type="reset" @click="clearForm" class="btn-clear">Clear</button>
      </div>
    </form>

    <!-- Success state -->
    <!-- :inert="!submitted" keeps the inner <a> non-focusable while hidden
         (SiteImprove "Hidden element has focusable content" — WCAG 2.1). -->
    <div
      x-cloak
      x-show="submitted"
      :inert="!submitted"
      role="alert"
      aria-live="assertive"
      style="text-align:center;margin-top:40px;color:var(--color-success-deep);font-weight:900;"
    >
      Your form was successfully submitted!
      <div style="color:var(--color-ink-near);font-weight:400;margin-top:8px;">
        &laquo;&nbsp;<a href="/" style="color:var(--color-ink-near);">Back to home</a>
      </div>
    </div>
  </div>
  </div>
</BaseLayout>

<style>
  /* Material Design-inspired form fields */
  .contact-form {
    margin-top: 16px;
  }

  .field-group {
    margin-bottom: 16px;
  }

  .field-label {
    display: block;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-ink-mid);
    margin-bottom: 4px;
  }

  .field-input {
    width: 100%;
    background: var(--color-surface-soft);
    border: none;
    border-bottom: 1px solid var(--color-border-input);
    border-radius: 0;
    padding: 1rem;
    font-size: 1rem;
    font-family: inherit;
    color: var(--color-ink);
    outline: none;
    transition: border-color 0.2s ease, border-bottom-width 0.1s ease;
    box-sizing: border-box;
  }

  .field-input:focus {
    border-bottom: 2px solid var(--color-input-focus);
    background: var(--color-surface-press);
  }

  textarea.field-input {
    min-height: 9rem;
  }

  .field-error {
    display: block;
    color: var(--color-error-text);
    font-size: 0.8rem;
    margin-top: 4px;
  }

  .form-error-banner {
    background: var(--color-error-bg);
    border-left: 4px solid var(--color-error-text);
    color: var(--color-error-deep);
    font-weight: 700;
    padding: 12px 16px;
    margin-bottom: 16px;
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: default;
  }

  /* .field-row layout now comes from Tailwind utilities inline
     (grid grid-cols-1 min-[600px]:grid-cols-2 gap-4). The 600 px
     breakpoint matches the prior @media (max-width: 600px) rule. */
  .field-row {
    margin-bottom: 0;
  }

  .form-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 8px;
  }

  .btn-submit {
    background: var(--color-button-bg); /* (legacy #0d4270 — button-bg split from --color-brand so it stays navy under white label in dark) */
    color: var(--color-on-dark);
    border: none;
    border-radius: 4px;
    padding: 10px 28px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
  }

  .btn-submit:hover {
    background: var(--color-button-bg-hover); /* (legacy #0a3050) */
  }

  .btn-clear {
    background: transparent;
    color: var(--color-brand);
    border: 2px solid var(--color-brand);
    border-radius: 4px;
    padding: 10px 28px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
  }

  .btn-clear:hover {
    background: var(--color-surface-chip);
  }

  /* (Mobile stack now driven by Tailwind grid-cols-1 default; the
     min-[600px]:grid-cols-2 utility takes over above 600 px.) */
</style>
