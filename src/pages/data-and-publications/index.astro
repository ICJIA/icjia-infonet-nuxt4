---
// astro/src/pages/data-and-publications/index.astro
//
// Port of app/pages/data-and-publications/index.vue (450 lines).
//
// Data source: app/data/dataAndPublications.json, copied to astro/src/data/.
// The JSON is a merged array of 'hub' articles (ICJIA Research Hub) and
// 'publist' items (PDFs from archive.icjia-api.cloud).
//
// Link logic:
//   source === 'hub'     → https://icjia.illinois.gov/researchhub/articles/<slug>
//   source === 'publist' → article.fileURL (PDF/external)
// Both open in a new window (external content).
//
// Tag filter chips: client-side Alpine.js chip-group. Tags are derived from
// the top-level `tags` array present on every item in dataAndPublications.json.
// Only high-value tags are surfaced in the chip bar (matching legacy chip-group).
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHeader from '~/components/PageHeader.astro';
import { formatDate } from '~/lib/dates';
import { gitLastModifiedISO } from '~/lib/gitDates';
import pubData from '~/data/dataAndPublications.json';
import splashManifest from '~/data/dap-splash-manifest.json';
type SplashEntry = { src: string; srcset: string; width: number; height: number };
const splashes = splashManifest.items as Record<string, SplashEntry>;

// Sort by date descending; items with no date go to bottom.
const articles = [...pubData].sort((a, b) => {
  const da = a.date ?? '';
  const db = b.date ?? '';
  return da > db ? -1 : da < db ? 1 : 0;
});

function getPublicationType(type: string | null | undefined): string {
  const map: Record<string, string> = {
    researchReport: 'Research Report',
    researchBulletin: 'Research Bulletin',
    researchAtAGlance: 'Research At A Glance',
    trendsAndIssuesUpdate: 'Trends and Issues Update',
    motorVehicleTheftPublications: 'Motor Vehicle Theft Publication',
    barj: 'BARJ',
    compiler: 'Compiler',
    dataset: 'Dataset',
    getTheFacts: 'GET THE FACTS',
    programEvaluationSummary: 'Program Evaluation Summary',
    megProfiles: 'MEG Profiles',
    annualReport: 'Annual Report',
    article: 'Article',
    report: 'Report',
    evaluation: 'Evaluation',
    toolkit: 'Toolkit',
    onGoodAuthority: 'On Good Authority',
    application: 'Application',
  };
  return type ? (map[type] ?? 'Publication') : 'Publication';
}

function getArticleHref(article: typeof articles[0]): string {
  if (article.source === 'hub') {
    return `https://icjia.illinois.gov/researchhub/articles/${article.slug}`;
  }
  return article.fileURL ?? '#';
}

// Curated tag chips that appear in the filter bar (matches legacy chip-group order).
const filterChips = [
  { label: 'All Research', value: 'all' },
  { label: 'InfoNet', value: 'infonet' },
  { label: 'Domestic Violence', value: 'domestic violence' },
  { label: 'Sexual Assault', value: 'sexual assault' },
  { label: 'Human Trafficking', value: 'human trafficking' },
  { label: 'Victim Services', value: 'victim services' },
];

// Serialize articles with their tags so Alpine can filter client-side.
const articlesJson = JSON.stringify(
  articles.map((a) => ({
    tags: (a as any).tags ?? [],
  })),
);
---
<BaseLayout
  title="InfoNet & Other Victim Services Research"
  breadcrumbTitle="Data and Publications"
  dateModified={gitLastModifiedISO('src/pages/data-and-publications/index.astro')}
>
  <PageHeader title="InfoNet &amp; Other Victim Services Research" />

  <div class="dap-page page-container" x-data={`dapFilter(${articlesJson})`}>
    <!-- Tag filter chips. aria-pressed mirrors the visual .active state so
         AT users can tell which filter is applied (toggle-button pattern);
         the static attribute carries the pre-hydration default ("all").
         The default chip's `active` class is ALSO server-rendered: if only
         Alpine adds it at hydration, the 150ms background/color transition
         fires on every load (visible flash; axe samples it mid-transition as
         a ~1.5:1 contrast fail). Alpine's :class object syntax still removes
         the class when another filter is chosen, even though it's static. -->
    <div class="tag-filters" role="group" aria-label="Filter by topic">
      {filterChips.map((chip) => (
        <button
          type="button"
          class:list={['tag-chip', { active: chip.value === 'all' }]}
          aria-pressed={chip.value === 'all' ? 'true' : 'false'}
          :class={`{ active: activeTag === ${JSON.stringify(chip.value)} }`}
          :aria-pressed={`activeTag === ${JSON.stringify(chip.value)}`}
          x-on:click={`activeTag = ${JSON.stringify(chip.value)}`}
        >
          {chip.label}
        </button>
      ))}
    </div>

    <!-- aria-live so filter changes announce the new result count. -->
    <p class="dap-count" aria-live="polite">
      <span x-text="visibleCount"></span>
      <span x-text="visibleCount === 1 ? ' item' : ' items'"></span>
    </p>

    <!-- 2-col card grid at ≥960 px (Vuetify md), stacked below. -->
    <div class="grid grid-cols-1 min-[960px]:grid-cols-2 gap-5 items-start">
      {articles.map((article, idx) => {
        const href = getArticleHref(article);
        const pubType = getPublicationType(article.pubType);
        const displayDate = formatDate(article.date, 'short');
        const abstract = article.abstract
          ? (article.abstract.length > 350 ? article.abstract.slice(0, 350) + '...' : article.abstract)
          : '';
        const splash = splashes[String(article._id)];
        // First card's splash is the LCP candidate above the fold —
        // eager-load with high priority to win Lighthouse's LCP-discovery
        // and image-delivery insights (was lazy → ~150 ms LCP penalty).
        const isLcpCandidate = idx === 0;
        return (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="dap-card-link"
            x-show={`isVisible(${idx})`}
          >
            <article class="dap-card">
              {splash && (
                <img
                  src={splash.src}
                  srcset={splash.srcset}
                  sizes="(min-width: 960px) 500px, 100vw"
                  width={splash.width}
                  height={splash.height}
                  alt=""
                  loading={isLcpCandidate ? 'eager' : 'lazy'}
                  fetchpriority={isLcpCandidate ? 'high' : 'auto'}
                  decoding="async"
                  class="dap-card-splash"
                />
              )}
              <div class="dap-card-body">
                <div class="dap-card-meta">
                  {displayDate && (
                    <span class="dap-card-date">{displayDate}</span>
                  )}
                  {displayDate && <span class="dap-card-sep"> | </span>}
                  <span class="dap-card-type">{pubType}</span>
                </div>
                <h2 class="dap-card-title">{article.title}</h2>
                {abstract && (
                  <p class="dap-card-abstract">{abstract}</p>
                )}
                <div class="dap-card-cta">
                  {article.source === 'hub'
                    ? 'Read Article (Web) »'
                    : `Read ${pubType} (${article.ext ?? 'link'}) »`}
                </div>
              </div>
            </article>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('alpine:init', () => {
    // @ts-ignore
    window.Alpine.data('dapFilter', (items: { tags: string[] }[]) => ({
      activeTag: 'all' as string,
      items,

      get visibleCount(): number {
        if (this.activeTag === 'all') return this.items.length;
        return this.items.filter((item) =>
          item.tags.includes(this.activeTag),
        ).length;
      },

      isVisible(idx: number): boolean {
        if (this.activeTag === 'all') return true;
        return this.items[idx]?.tags?.includes(this.activeTag) ?? false;
      },
    }));
  });
</script>

<style>
  .dap-page {
    max-width: 1100px;
  }

  /* Tag filter chip bar */
  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .tag-chip {
    background: var(--color-surface-chip);
    color: var(--color-brand);
    border: 1px solid var(--color-border-chip);
    border-radius: 22px;
    padding: 4px 14px;
    /* 2.5.5 (AAA): pointer targets ≥44px — chips were 30px tall */
    min-height: 44px;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .tag-chip:hover {
    background: var(--color-surface-chip-hover);
  }

  .tag-chip.active {
    background: var(--color-button-bg); /* (legacy #0d4270 — button-bg split from --color-brand so it stays navy under white label in dark) */
    color: var(--color-on-dark);
    border-color: var(--color-button-bg);
  }

  .dap-count {
    color: var(--color-ink-soft); /* 7.46:1 — 1.4.6 (AAA) needs 7:1 */
    font-size: 0.875rem;
    margin-bottom: 16px;
  }

  /* DAP grid: replaced by Tailwind utilities inline
     (grid grid-cols-1 min-[960px]:grid-cols-2 gap-5 items-start) —
     mirrors legacy Vuetify <v-row><v-col cols=12 md=6>. */

  .dap-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .dap-card {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-surface-faint);
    height: 100%;
    box-sizing: border-box;
    transition: box-shadow 0.2s ease;
    overflow: hidden;
  }

  .dap-card-splash {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background: var(--color-surface-press);
    border-bottom: 1px solid var(--color-border);
  }

  .dap-card-body {
    padding: 16px 20px;
  }

  .dap-card-link:hover .dap-card {
    box-shadow: 0 4px 12px var(--shadow-color-soft); /* (legacy rgba(0,0,0,0.12)) */
  }

  .dap-card-meta {
    font-size: 0.75rem;
    margin-bottom: 8px;
  }

  .dap-card-date {
    font-weight: 700;
    color: var(--color-ink-max);
    text-transform: uppercase;
  }

  .dap-card-sep {
    /* SiteImprove checks punctuation-only text nodes (axe skips them) — the "|"
       must pass like any text. sia-r69 (AA) wanted 4.5:1; sia-r66 (AAA) wants
       7:1, so ink-soft: 7.1:1 on #fafafa light / 7.9:1 dark. */
    color: var(--color-ink-soft);
  }

  .dap-card-type {
    color: var(--color-ink-soft);
    text-transform: uppercase;
  }

  .dap-card-title {
    margin: 0 0 10px;
    font-size: 1rem;
    font-weight: 900;
    color: var(--color-brand);
  }

  .dap-card-abstract {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-ink-mid);
    line-height: 1.55;
  }

  .dap-card-cta {
    text-align: right;
    margin-top: 10px;
    font-size: 0.75rem;
    font-weight: 900;
    /* WCAG AA: #1976d2 on #fafafa is 4.28:1 (fails 4.5:1 for small bold).
       #0d47a1 (Blue 900) reaches ~6.6:1 — passes AA and AAA for normal text. */
    color: var(--color-link-strong);
  }
</style>
