---
// astro/src/pages/tabs/[...slug].astro
//
// Strapi "tabs" catch-all — generates one static route per CMS tab.
// Tabs are sub-pages within DV, SA, and CAC sections (the sectionID field
// identifies which section each tab belongs to).
//
// QUERY_TAB_LIST (added in Phase 3 queries.ts) fetches all tab slugs
// for build-time static path generation.
// Phase 7: MDC detection wired for completeness (tab bodies are unlikely to
// contain top-level MDC refs, but handled consistently).
import BaseLayout from '~/layouts/BaseLayout.astro';
import DvAwarenessMonth from '~/components/mdc/DvAwarenessMonth.astro';
import Partners from '~/components/mdc/Partners.astro';
import TabsScreenshotsAccessible from '~/components/mdc/TabsScreenshotsAccessible.astro';
import TabsUserInfoAccessible from '~/components/mdc/TabsUserInfoAccessible.astro';
import { strapiFetch } from '~/lib/strapi';
import { QUERY_TAB_LIST } from '~/lib/queries';
import { TabListResponseSchema } from '~/lib/schemas';
import { renderMarkdown } from '~/lib/markdown';

// ---------------------------------------------------------------------------
// MDC detection helper
// ---------------------------------------------------------------------------
function detectMdcComponent(body: string | null | undefined): { name: string; props: Record<string, string> } | null {
  if (!body) return null;
  const blockMatch = body.trim().match(/^::([A-Z][a-zA-Z]+)\n---\n((?:.|\n)*?)\n---\n::$/);
  if (blockMatch) {
    const props: Record<string, string> = {};
    if (blockMatch[2]) {
      for (const line of blockMatch[2].split('\n')) {
        const colonIdx = line.indexOf(':');
        if (colonIdx === -1) continue;
        const k = line.slice(0, colonIdx).trim();
        const v = line.slice(colonIdx + 1).trim().replace(/^"(.*)"$/, '$1');
        if (k) props[k] = v;
      }
    }
    return { name: blockMatch[1], props };
  }
  const inlineMatch = body.trim().match(/^:([A-Z][a-zA-Z]+)$/);
  if (inlineMatch) return { name: inlineMatch[1], props: {} };
  return null;
}

export async function getStaticPaths() {
  const raw = await strapiFetch(QUERY_TAB_LIST);
  const parsed = TabListResponseSchema.parse(raw);

  // Filter out tabs with null/undefined slugs — they cannot be routed.
  return parsed.tabs.data
    .filter((tab) => Boolean(tab.attributes.slug))
    .map((tab) => ({
      params: { slug: tab.attributes.slug! },
      props: { tab },
    }));
}

const { tab } = Astro.props;
const attr = tab.attributes;

const mdc = detectMdcComponent(attr.body);
const { html } = mdc ? { html: '' } : renderMarkdown(attr.body);

const description = attr.summary ?? attr.title ?? '';
---
<BaseLayout
  title={attr.title ?? 'Tab'}
  description={description}
  breadcrumbTitle={attr.title ?? undefined}
>
  <article class="tab-detail">
    {attr.sectionID && (
      <p class="tab-section-label" aria-label="Section">
        {attr.sectionID.toUpperCase()}
      </p>
    )}
    <h1>{attr.title}</h1>
    {mdc ? (
      mdc.name === 'DvAwarenessMonth' ? <DvAwarenessMonth /> :
      mdc.name === 'Partners' ? <Partners /> :
      mdc.name === 'TabsScreenshotsAccessible' ? <TabsScreenshotsAccessible sectionID={mdc.props.sectionID ?? 'screenshots'} /> :
      mdc.name === 'TabsUserInfoAccessible' ? <TabsUserInfoAccessible sectionID={mdc.props.sectionID ?? 'users'} /> :
      <div class="markdown-body" set:html={html}></div>
    ) : (
      <div class="markdown-body" set:html={html}></div>
    )}
  </article>
</BaseLayout>

<style>
  .tab-detail {
    max-width: 800px;
    padding: 0 1rem 3rem;
  }

  .tab-section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #666;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .tab-detail h1 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 900;
    line-height: 1.2;
    color: #0d4270;
    margin-bottom: 1.5rem;
    margin-top: 0;
  }
</style>
