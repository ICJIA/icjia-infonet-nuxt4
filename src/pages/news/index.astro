---
// astro/src/pages/news/index.astro
//
// News listing: featured SplashNews card for the newest post, then InfoCard
// grid for the rest. Replaced SimpleCard (Phase 5a).
import BaseLayout from '~/layouts/BaseLayout.astro';
import SplashNews from '~/components/SplashNews.astro';
import InfoCard from '~/components/InfoCard.astro';
import { strapiFetch } from '~/lib/strapi';
import { QUERY_POST_LIST } from '~/lib/queries';
import { PostListResponseSchema } from '~/lib/schemas';

const raw = await strapiFetch(QUERY_POST_LIST);
const parsed = PostListResponseSchema.parse(raw);
const displayDate = (p: (typeof parsed.posts.data)[number]) =>
  p.attributes.dateOverride ?? p.attributes.createdAt ?? null;
const posts = parsed.posts.data.sort(
  (a, b) => new Date(displayDate(b) ?? 0).getTime() - new Date(displayDate(a) ?? 0).getTime()
);
const [first, ...rest] = posts;
---
<BaseLayout title="News" breadcrumbTitle="News">
  <h1>News &amp; Updates</h1>

  {first && <SplashNews post={first} />}

  {rest.length > 0 && (
    <div class="news-grid">
      {rest.map((p) => <InfoCard post={p} />)}
    </div>
  )}
</BaseLayout>

<style>
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 8px;
  }
</style>
