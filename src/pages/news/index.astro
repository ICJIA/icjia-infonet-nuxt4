---
// astro/src/pages/news/index.astro
//
// News listing: uniform 2-column grid of NewsCard components.
// Sorted by dateOverride ?? createdAt descending. Matches legacy news/index.vue.
import BaseLayout from '~/layouts/BaseLayout.astro';
import NewsCard from '~/components/NewsCard.astro';
import { gitLastModifiedISO } from '~/lib/gitDates';
import { strapiFetch, assertNoTruncation } from '~/lib/strapi';
import { QUERY_POST_LIST } from '~/lib/queries';
import { PostListResponseSchema } from '~/lib/schemas';

const raw = await strapiFetch(QUERY_POST_LIST);
const parsed = PostListResponseSchema.parse(raw);
assertNoTruncation('posts (news listing)', parsed.posts.data.length, parsed.posts.meta?.pagination?.total);

const displayDate = (p: (typeof parsed.posts.data)[number]) =>
  p.attributes.dateOverride ?? p.attributes.createdAt ?? null;

const posts = parsed.posts.data.sort(
  (a, b) => new Date(displayDate(b) ?? 0).getTime() - new Date(displayDate(a) ?? 0).getTime()
);
---
<BaseLayout title="News" breadcrumbTitle="News" dateModified={gitLastModifiedISO('src/pages/news/index.astro')}>
  <div class="news-page page-container">
    <h1 class="news-page__heading">News &amp; Updates</h1>
    <div class="news-page__rule"></div>

    <!-- 2-col card grid at ≥960 px (Vuetify md), stacked below. -->
    <div class="grid grid-cols-1 min-[960px]:grid-cols-2 gap-6">
      {posts.map((p) => <NewsCard post={p} />)}
    </div>
  </div>
</BaseLayout>

<style>
  .news-page__heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    margin: 1rem 0 0.5rem;
    padding: 0;
    color: var(--color-ink);
    border: none;
    text-align: center;
  }

  .news-page__rule {
    border-top: 1px solid var(--color-ink);
    margin-bottom: 2.5rem;
  }

  /* News grid: replaced by Tailwind utilities inline
     (grid grid-cols-1 min-[960px]:grid-cols-2 gap-6) — mirrors
     legacy Vuetify <v-row><v-col cols=12 md=6>. */
</style>
