---
// astro/src/pages/news/[slug].astro
//
// Dynamic post detail page — one route per Strapi post slug.
// Phase 5a: uses CmsImage for optimised splash + PostedMeta/LastUpdated.
// Phase 7: MDC component detection — renders DvAwarenessMonth/Partners/Tabs
//           components when body is a bare MDC reference.
import BaseLayout from '~/layouts/BaseLayout.astro';
import CmsImage from '~/components/CmsImage.astro';
import PostedMeta from '~/components/PostedMeta.astro';
import LastUpdated from '~/components/LastUpdated.astro';
import ReadProgress from '~/components/ReadProgress.astro';
import Toc from '~/components/Toc.astro';
import DvAwarenessMonth from '~/components/mdc/DvAwarenessMonth.astro';
import Partners from '~/components/mdc/Partners.astro';
import TabsScreenshotsAccessible from '~/components/mdc/TabsScreenshotsAccessible.astro';
import TabsUserInfoAccessible from '~/components/mdc/TabsUserInfoAccessible.astro';
import { strapiFetch } from '~/lib/strapi';
import { QUERY_POST_LIST } from '~/lib/queries';
import { PostListResponseSchema } from '~/lib/schemas';
import { renderMarkdown } from '~/lib/markdown';

// ---------------------------------------------------------------------------
// MDC detection helper
// ---------------------------------------------------------------------------
function detectMdcComponent(body: string | null | undefined): { name: string; props: Record<string, string> } | null {
  if (!body) return null;
  // Block form: ::ComponentName\n---\nprop: value\n---\n::
  const blockMatch = body.trim().match(/^::([A-Z][a-zA-Z]+)\n---\n((?:.|\n)*?)\n---\n::$/);
  if (blockMatch) {
    const props: Record<string, string> = {};
    if (blockMatch[2]) {
      for (const line of blockMatch[2].split('\n')) {
        const colonIdx = line.indexOf(':');
        if (colonIdx === -1) continue;
        const k = line.slice(0, colonIdx).trim();
        const v = line.slice(colonIdx + 1).trim().replace(/^"(.*)"$/, '$1');
        if (k) props[k] = v;
      }
    }
    return { name: blockMatch[1], props };
  }
  // Inline form: :ComponentName as the entire body
  const inlineMatch = body.trim().match(/^:([A-Z][a-zA-Z]+)$/);
  if (inlineMatch) return { name: inlineMatch[1], props: {} };
  return null;
}

export async function getStaticPaths() {
  const raw = await strapiFetch(QUERY_POST_LIST);
  const parsed = PostListResponseSchema.parse(raw);
  return parsed.posts.data.map((post) => ({
    params: { slug: post.attributes.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const attr = post.attributes;

// Date precedence: dateOverride > createdAt
const displayDate = attr.dateOverride ?? attr.createdAt ?? null;

const mdc = detectMdcComponent(attr.body);
const { html, headings } = mdc ? { html: '', headings: [] } : renderMarkdown(attr.body);

// Splash image — Strapi v4 nested under data.attributes
const splashAttr = attr.splash?.data?.attributes;
const splashUrl = splashAttr?.url
  ? (splashAttr.url.startsWith('http') ? splashAttr.url : `https://infonet.icjia-api.cloud${splashAttr.url}`)
  : null;
const splashAlt = splashAttr?.alternativeText?.trim()
  || splashAttr?.caption?.trim()
  || `${attr.title ?? ''} — article splash image`;

// Show "Updated" note only when updatedAt is meaningfully different (>1 day).
function daysDiff(a: string | null | undefined, b: string | null | undefined): number {
  if (!a || !b) return 0;
  const da = new Date(a).getTime();
  const db = new Date(b).getTime();
  if (Number.isNaN(da) || Number.isNaN(db)) return 0;
  return Math.abs(db - da) / 86_400_000;
}
const showUpdated = daysDiff(attr.createdAt, attr.updatedAt) > 1;

const description = attr.summary ?? attr.title ?? '';
---
<BaseLayout
  title={attr.title ?? 'News'}
  description={description}
  ogImage={splashUrl ?? undefined}
  breadcrumbTitle="News"
  breadcrumbTitleHref="/news/"
  breadcrumbCurrent={attr.title ?? undefined}
>
  <ReadProgress />
  <article class="post-detail">
    <header class="post-header">
      <h1>{attr.title}</h1>
      <PostedMeta date={displayDate} author={attr.category ?? undefined} />
    </header>
    {headings.length >= 2 && <Toc headings={headings} />}

    {splashUrl && (
      <figure class="post-splash">
        <CmsImage
          src={splashUrl}
          alt={splashAlt}
          loading="eager"
          fetchpriority="high"
          sizes="(min-width: 960px) 800px, 100vw"
          class="post-splash__img"
        />
        {splashAttr?.caption?.trim() && (
          <figcaption>{splashAttr.caption.trim()}</figcaption>
        )}
      </figure>
    )}

    {mdc ? (
      mdc.name === 'DvAwarenessMonth' ? <DvAwarenessMonth /> :
      mdc.name === 'Partners' ? <Partners /> :
      mdc.name === 'TabsScreenshotsAccessible' ? <TabsScreenshotsAccessible sectionID={mdc.props.sectionID ?? 'screenshots'} /> :
      mdc.name === 'TabsUserInfoAccessible' ? <TabsUserInfoAccessible sectionID={mdc.props.sectionID ?? 'users'} /> :
      <div class="markdown-body" set:html={html}></div>
    ) : (
      <div class="markdown-body" set:html={html}></div>
    )}

    {showUpdated && (
      <LastUpdated date={attr.updatedAt} />
    )}
  </article>
</BaseLayout>

<style>
  .post-detail {
    max-width: 800px;
    padding: 0 1rem 3rem;
  }

  .post-header h1 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 900;
    line-height: 1.2;
    color: #0d4270;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  .post-splash {
    margin: 0 0 2rem;
  }

  .post-splash__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    max-height: 550px;
  }

  .post-splash figcaption {
    font-size: 0.75rem;
    color: #666;
    font-weight: 700;
    margin-top: 0.25rem;
    padding-left: 0.25rem;
  }
</style>
