---
// astro/src/pages/search.astro
//
// Pagefind UI search page. Pagefind assets are generated during `pnpm build`
// (pagefind --site dist) and served from /pagefind/. The UI is initialised
// client-side via is:inline script tags to avoid Vite bundling issues.
// ?q= deep-link: reads the URL search param and sets the Pagefind input value
// after the UI registers (~100 ms timeout lets it bind its event listeners).
//
// Legacy: app/pages/search.vue used Fuse.js against /api/search endpoint —
// replaced by Pagefind for static-site full-text search.
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHeader from '~/components/PageHeader.astro';
import { gitLastModifiedISO } from '~/lib/gitDates';
---
{/* searchable={false}: the search page must not appear in its own results. */}
<BaseLayout title="Search" breadcrumbTitle="Search" searchable={false} dateModified={gitLastModifiedISO('src/pages/search.astro')}>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

  <div class="search-wrapper">
    <PageHeader title="Search" />
    <div id="pagefind-ui"></div>
  </div>

  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    (function () {
      // showSubResults: result cards list per-section hits (split on ids in
      // the indexed page), so an FAQ match links to /faqs/#faq-<slug> and
      // the faqs page script opens that accordion on arrival.
      new PagefindUI({ element: '#pagefind-ui', showImages: false, showSubResults: true });

      // ?q= deep-link: pre-fill query from URL params and trigger search.
      var params = new URLSearchParams(window.location.search);
      var q = params.get('q');
      if (q) {
        // Wait ~100 ms so Pagefind UI can bind its own event listeners first.
        setTimeout(function () {
          var input = document.querySelector('#pagefind-ui input[type="text"]');
          if (input) {
            input.value = q;
            input.dispatchEvent(new Event('input', { bubbles: true }));
          }
        }, 100);
      }
    })();
  </script>
</BaseLayout>

<style>
  .search-wrapper {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 1rem 3rem;
  }

  /* Pagefind UI custom properties → site tokens, so phase 2's dark palette
     re-themes search for free. */
  :global(#pagefind-ui) {
    --pagefind-ui-text: var(--color-ink);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border-input);
    --pagefind-ui-primary: var(--color-link-strong);
    /* result-tag chips (unused today — no tags/filters indexed). Light value
       #eee matches Pagefind's #eeeeee default exactly; mapped so any future
       tag rendering follows the dark palette instead of glowing light. */
    --pagefind-ui-tag: var(--color-surface-press);
  }

  /* Override Pagefind UI defaults to blend with site typography */
  :global(#pagefind-ui .pagefind-ui__search-input) {
    border-radius: 4px;
    border: 1px solid var(--color-border-input);
  }

  /* Result cards — subtle shaded treatment matching dvfr.illinois.gov's
     search-result-card: #f7f7f9 fill, hairline border, soft shadow, gentle
     shadow lift on hover. Replaces Pagefind's default border-top dividers. */
  :global(#pagefind-ui .pagefind-ui__result) {
    border-top: none;
    margin: 16px 0;
    padding: 20px 24px;
    border: 1px solid var(--color-border-card);
    border-radius: 4px;
    background: var(--color-surface-card);
    box-shadow: 0 1px 2px var(--shadow-color-faint); /* (legacy rgba(0,0,0,0.04)) */
    transition: box-shadow 0.2s ease-in-out;
  }

  :global(#pagefind-ui .pagefind-ui__result:hover) {
    box-shadow: 0 4px 8px var(--shadow-color-soft); /* (legacy rgba(0,0,0,0.12)) */
  }

  :global(#pagefind-ui .pagefind-ui__result mark) {
    background: var(--color-mark);
    color: var(--color-mark-ink); /* (legacy: inherited #222 via --pagefind-ui-text — amber highlight needs dark text in BOTH modes) */
    padding: 0 1px;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(#pagefind-ui .pagefind-ui__result) {
      transition: none;
    }
  }

  :global(#pagefind-ui .pagefind-ui__search-clear) {
    color: var(--color-ink-soft);
  }

  :global(#pagefind-ui .pagefind-ui__result-link) {
    /* #0d47a1 (Blue 900, same as the DAP card CTA): ~6.3:1 on the #f7f7f9
       card fill. The old var(--color-primary) #1976d2 was 4.36:1 there —
       under the 4.5:1 AA minimum once the shaded cards landed. */
    color: var(--color-link-strong);
  }
</style>
