---
// astro/src/layouts/BaseLayout.astro
//
// Single layout used by every page. Per v6 checklist: skip-link off-screen
// pattern, Plausible bare script, URL normalizer, astro-seo + canonical.
import { SEO } from 'astro-seo';
import { siteConfig } from '~/lib/siteConfig';
import AppNav from '~/components/AppNav.astro';
import AppSidebar from '~/components/AppSidebar.astro';
import AppFooter from '~/components/AppFooter.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import '~/styles/global.css';

// Preload the three most-used woff2 files so they download in parallel with CSS
// instead of waiting for the @fontsource @import chain to be parsed. Removes the
// late font-swap reflow that was costing ~0.12 CLS on text-heavy pages.
// Raleway 900 is the brand font ("INFONET" in the fixed header, above the fold
// on every page); Lato 400/700 cover body text. Roboto was dropped site-wide.
// `?url` resolves to the same hashed /_astro/... asset the CSS rule references,
// so the browser reuses the preloaded byte stream (no duplicate fetch).
import latoRegularUrl from '@fontsource/lato/files/lato-latin-400-normal.woff2?url';
import latoBoldUrl from '@fontsource/lato/files/lato-latin-700-normal.woff2?url';
import ralewayBlackUrl from '@fontsource/raleway/files/raleway-latin-900-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  /**
   * Whether Pagefind may index this page (`data-pagefind-body` on <main>).
   * Defaults to `!noindex`, so 404/debug/tabs pages drop out of site search
   * automatically; pages can also opt out explicitly (search page, CMS
   * entries with `hideFromSearch`).
   */
  searchable?: boolean;
  canonicalOverride?: string;
  breadcrumbTitle?: string;
  /** Optional href for the middle breadcrumb entry (makes it a link). */
  breadcrumbTitleHref?: string;
  /** Optional current-page label for 3-level breadcrumb. */
  breadcrumbCurrent?: string | null;
  /** Structured news article data — emits NewsArticle JSON-LD + article:published_time/modified_time meta. */
  newsArticle?: {
    headline: string;
    description: string;
    datePublished: string;
    dateModified: string;
    image?: string;
  };
  /** WebPage JSON-LD `datePublished` (non-news pages). Defaults to the site
   *  launch date; CMS pages pass their real Strapi publishedAt/createdAt
   *  (nullable — null falls back to the launch date). */
  datePublished?: string | null;
  /** WebPage JSON-LD `dateModified` (non-news pages). Omitted when null/absent —
   *  CMS pages pass Strapi updatedAt; hand-authored pages pass their source
   *  file's git last-commit date (see ~/lib/gitDates). Never a build stamp. */
  dateModified?: string | null;
  /** Explicit JSON-LD override (used by the home page for combined WebSite + Organization schema). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = siteConfig.defaultDescription,
  ogImage,
  noindex = false,
  searchable = !noindex,
  canonicalOverride,
  breadcrumbTitle = undefined,
  breadcrumbTitleHref = undefined,
  breadcrumbCurrent = undefined,
  newsArticle,
  datePublished,
  dateModified,
  jsonLd,
} = Astro.props;

// Canonical URL — strip /index.html / .html (Astro static format edge case);
// always end in trailing slash. Subdomain mount: no base path stripping needed.
const rawPath = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '');
const canonical = canonicalOverride
  ?? new URL(rawPath, Astro.site ?? siteConfig.siteOrigin).toString();

const fullTitle = title
  ? `ICJIA | ${title}`
  : siteConfig.siteName;

// JSON-LD structured data — page-type aware. Order of precedence:
//   1. Explicit `jsonLd` override (home: WebSite + Organization)
//   2. `newsArticle` prop → built NewsArticle schema with full Strapi dates
//   3. Default WebPage schema with canonical + description + ICJIA publisher
const newsArticleJsonLd = newsArticle && {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: newsArticle.headline,
  description: newsArticle.description,
  url: canonical,
  datePublished: newsArticle.datePublished,
  dateModified: newsArticle.dateModified,
  inLanguage: 'en-US',
  image: [newsArticle.image ?? siteConfig.og.image],
  author: { '@type': 'Organization', name: siteConfig.author, url: 'https://icjia.illinois.gov' },
  publisher: {
    '@type': 'GovernmentOrganization',
    name: siteConfig.author,
    url: 'https://icjia.illinois.gov',
    logo: { '@type': 'ImageObject', url: 'https://infonet.icjia.illinois.gov/icjia-logo.png' },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};

// `dateModified` is sourced honestly, never build-stamped (a build-time stamp
// makes every page look changed on every deploy, teaching crawlers to ignore
// the site's freshness signals): CMS pages pass Strapi updatedAt, hand-authored
// pages pass their source file's git last-commit date (~/lib/gitDates), and it
// is omitted entirely when neither is available rather than faked. datePublished
// likewise defaults to the launch date only when a page has no real date.
const defaultWebPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  url: canonical,
  name: fullTitle,
  description,
  inLanguage: 'en-US',
  datePublished: datePublished ?? siteConfig.siteLaunchDate,
  ...(dateModified ? { dateModified } : {}),
  isPartOf: {
    '@type': 'WebSite',
    name: siteConfig.siteName,
    url: siteConfig.siteOrigin,
  },
  publisher: {
    '@type': 'GovernmentOrganization',
    name: siteConfig.author,
    url: 'https://icjia.illinois.gov',
  },
};

// Coerce to an array of entries so each gets its own <script> tag with
// `@type` at the root — AI-readiness scanners that JSON.parse() the script
// content look for `result.@type` and fail on raw arrays.
const effectiveJsonLd = jsonLd ?? newsArticleJsonLd ?? defaultWebPageJsonLd;
const jsonLdEntries: Array<Record<string, unknown>> = Array.isArray(effectiveJsonLd)
  ? effectiveJsonLd
  : [effectiveJsonLd];

// JSON.stringify does NOT escape `<`, and `set:html` is raw insertion — a CMS
// title containing `</script>` would otherwise break out of the JSON-LD block
// into <head>. `<` is valid JSON, so parsers are unaffected.
const toJsonLdHtml = (entry: Record<string, unknown>) =>
  JSON.stringify(entry).replace(/</g, '\\u003c');

// Conditional <main> top-padding: home gets 64px; other pages get 96px.
const isHome = rawPath === '/';
/* Legacy measured gap from breadcrumb-bottom to h1-top = 32px on non-home.
   Home renders the gray .home-section--gray hero edge-to-edge, so it needs
   ZERO top padding — otherwise a white strip shows between the nav and the
   gray background. */
const mainTopPad = isHome ? 0 : 32;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" />
    {/* Theme init — applies .dark before first paint. Order: ?theme= test
        override (not persisted) → localStorage 'theme' → LIGHT default.
        Deliberately NO prefers-color-scheme sniffing: the site defaults to
        its standard light look for everyone; dark is an explicit opt-in
        (user decision 2026-06-10). Inline + hashed in the CSP (netlify.toml)
        — re-run pnpm csp-hashes after ANY edit to this script. */}
    <script is:inline>
      (function () {
        try {
          var p = new URLSearchParams(location.search).get('theme');
          var s = localStorage.getItem('theme');
          var t = p === 'dark' || p === 'light' ? p : s;
          if (t === 'dark') {
            document.documentElement.classList.add('dark');
            var m = document.querySelector('meta[name="theme-color"]');
            if (m) m.setAttribute('content', '#14171c');
          }
        } catch (e) {}
      })();
    </script>
    {/* Permissions-Policy is sent as a real response header (netlify.toml) —
        the directive is header-only, so a <meta http-equiv> version is inert. */}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <link rel="preload" as="font" type="font/woff2" href={latoRegularUrl} crossorigin="anonymous" />
    <link rel="preload" as="font" type="font/woff2" href={latoBoldUrl} crossorigin="anonymous" />
    <link rel="preload" as="font" type="font/woff2" href={ralewayBlackUrl} crossorigin="anonymous" />

    <SEO
      title={fullTitle}
      description={description}
      canonical={canonical}
      noindex={noindex}
      openGraph={{
        basic: {
          title: fullTitle,
          type: newsArticle ? 'article' : 'website',
          image: ogImage ?? siteConfig.og.image,
          url: canonical,
        },
        optional: {
          description,
          siteName: siteConfig.siteName,
          locale: 'en_US',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        image: ogImage ?? siteConfig.og.image,
        imageAlt: siteConfig.siteName,
      }}
      extend={{
        meta: [
          { name: 'author', content: siteConfig.author },
          ...(siteConfig.og.fbAppId
            ? [{ property: 'fb:app_id', content: siteConfig.og.fbAppId }]
            : []),
        ],
      }}
    />

    {newsArticle && (
      <>
        <meta property="article:published_time" content={newsArticle.datePublished} />
        <meta property="article:modified_time" content={newsArticle.dateModified} />
      </>
    )}

    {jsonLdEntries.map((entry) => (
      <script is:inline type="application/ld+json" set:html={toJsonLdHtml(entry)} />
    ))}

    {/* URL normalizer — runs before deferred Plausible. */}
    <script is:inline>
      if (location.pathname !== '/' && !location.pathname.endsWith('/')) {
        history.replaceState(
          null,
          '',
          location.pathname + '/' + location.search + location.hash,
        );
      }
    </script>

    {/* Plausible — bare script tag with data-domain. */}
    <script
      is:inline
      defer
      data-domain={siteConfig.plausible.domain}
      src={siteConfig.plausible.scriptSrc}
    ></script>
  </head>

  <body>
    <nav class="skip-links" aria-label="Skip links">
      <a href="#main-content" class="skip-link">Skip to main content</a>
      <a href="#main-navigation" class="skip-link">Skip to navigation</a>
    </nav>

    <AppNav />
    <AppSidebar />
    <Breadcrumb title={breadcrumbTitle} breadcrumbTitleHref={breadcrumbTitleHref} breadcrumbCurrent={breadcrumbCurrent} />

    {/* tabindex="-1": the "Skip to main content" link must move PROGRAMMATIC
        focus here — without it, activeElement stays on <body> and screen
        readers aren't relocated (matches #main-navigation, which already
        carries it). Not in the tab order; outline suppressed below. */}
    <main id="main-content" tabindex="-1" data-pagefind-body={searchable ? '' : undefined} style={`padding-top: ${mainTopPad}px; min-height: 70vh;`}>
      <slot />
    </main>

    <AppFooter />

    <style is:global>
      /* Clear the fixed AppNav (80px tall) — content + Breadcrumb start below */
      body { padding-top: 80px; }

      .skip-link,
      .skip-links {
        position: absolute;
        top: -100px;
      }
      .skip-link {
        background: var(--color-ink-max);
        /* color/border use --color-surface (NOT --color-on-dark): the chip
           background is --color-ink-max, which flips near-white in dark
           mode — on-dark text would be white-on-white there. surface flips
           opposite (white in light, near-black in dark), so the chip stays
           max-contrast in both themes. Found by a keyboard-focus audit;
           static screenshots never show focused skip links. */
        color: var(--color-surface);
        padding: 8px 16px;
        left: 8px;
        border: 2px solid var(--color-surface);
        border-radius: 4px;
        z-index: 10001;
      }

      /* Programmatic-focus target only (tabindex="-1", not tabbable) — the
         default outline would draw a ring around the entire page column. */
      #main-content:focus {
        outline: none;
      }
      @media (prefers-reduced-motion: no-preference) {
        .skip-link { transition: top 0.3s ease; }
      }
      .skip-link:focus,
      .skip-link:active {
        position: fixed;
        top: 8px;
        left: 8px;
      }
    </style>

    <script>
      import '~/scripts/alpine-entry';
    </script>
  </body>
</html>
