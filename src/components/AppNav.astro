---
// astro/src/components/AppNav.astro
//
// Port of legacy app/components/content/TheNav.vue.
// Visual spec:
//   - <nav id="main-navigation"> landmark — skip-link target in BaseLayout
//   - Height 150px (legacy v-app-bar size="150px"), z-index 50
//   - Background white, drop-shadow (elevation 3)
//   - Mobile/tablet (< 1280px): hamburger + "INFONET" abbreviated title + search icon
//   - Desktop (≥ 1280px): full title + topNav links (dropdown via <details>) + utility ⋮ dropdown
//
// Hamburger pattern: drawer state lives in Alpine.store('drawer') (registered
//   in scripts/alpine-entry.ts). The hamburger toggles the store and binds
//   aria-expanded / aria-label to it, so every close path (Escape, backdrop,
//   nav-link click in AppSidebar) keeps the button in sync — the old
//   CustomEvent pattern let the button's state invert permanently.
//
// Title font spec (from TheNav.vue inline styles):
//   - Font: Raleway, 28px desktop / 28px mobile
//   - "INFONET" in var(--color-brand) (legacy #0d4270) font-weight 900
//   - " | DATA COLLECTION & REPORTING SYSTEM" in var(--color-ink-max) (legacy #000) (visually light;
//     rendered at 400 — Raleway 300 is not shipped, so browsers substituted
//     400 anyway and the explicit 400 just makes that honest)
//
// Dropdown items: native <details><summary> disclosure (no Alpine state — full
// keyboard a11y). Deliberately NO role="menu"/"menuitem": ARIA menus promise
// arrow-key/typeahead behavior we don't implement, and the APG recommends
// plain disclosure semantics for navigation links.
// Active route: <a aria-current="page"> when pathname matches.
//
// Breakpoint: desktop nav (brand subtitle + topNav links + ⋮) appears at ≥960px.
// This matches legacy behaviour at 1072px viewport (desktop nav shown, not hamburger).

import { topNav, utilityLinks } from '~/lib/menu';
const pathname = Astro.url.pathname;
---

<header style="position: fixed; top: 0; left: 0; width: 100%; z-index: 50; background: var(--color-surface); box-shadow: var(--shadow-elevation-6);">
  <nav
    id="main-navigation"
    aria-label="Main"
    tabindex="-1"
    style="
      display: flex;
      align-items: center;
      width: 100%;
      height: 80px;
      padding: 0 20px;
      box-sizing: border-box;
    "
  >
    <!-- ── Hamburger (mobile/tablet, < 960px) ───────────────────────── -->
    <button
      type="button"
      id="nav-hamburger"
      x-data
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-navigation"
      :aria-expanded="$store.drawer.open"
      :aria-label="$store.drawer.open ? 'Close navigation menu' : 'Open navigation menu'"
      @click="$store.drawer.toggle()"
      class="nav-hamburger md-hide"
      style="
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 8px;
        min-width: 44px;
        min-height: 44px;
        color: var(--color-ink-87);
      "
    >
      <!-- Hamburger icon — MDI menu path -->
      <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M3 6h18v2H3V6m0 5h18v2H3v-2m0 5h18v2H3v-2"/>
      </svg>
      <span style="font-size: 10px; font-weight: 900; letter-spacing: 0.04em; text-transform: uppercase;">Menu</span>
    </button>

    <!-- ── Spacer (mobile only) ──────────────────────────────────────── -->
    <div class="md-hide" style="flex: 1;"></div>

    <!-- ── Title (desktop) ──────────────────────────────────────────── -->
    <!-- No aria-label: the three inline <span>s compute the accessible name
         "INFONET | Data Collection & Reporting System", which axe 4.11 wants
         to match the visible text exactly (rule: label-content-name-mismatch).
         The tagline is title-case in the DOM and uppercased by CSS — same pixels,
         but assistive tech reads it as words (Siteimprove "Text in all caps"). -->
    <a
      href="/"
      class="md-show"
      style="text-decoration: none;"
    >
      <span style="
        font-weight: 900;
        font-size: 28px;
        font-family: 'Raleway', sans-serif;
        letter-spacing: 0em;
        color: var(--color-brand);
        white-space: nowrap;
      ">INFONET</span>
      <span style="
        font-weight: 900;
        font-size: 28px;
        font-family: 'Raleway', sans-serif;
        color: var(--color-brand);
        margin: 0 6px;
      ">&nbsp;|&nbsp;</span>
      <span style="
        font-weight: 400;
        font-size: 26px;
        font-family: 'Raleway', sans-serif;
        letter-spacing: 0px;
        color: var(--color-ink-max);
        white-space: nowrap;
        text-transform: uppercase;
      ">Data Collection &amp; Reporting System</span>
    </a>

    <!-- ── Title (mobile — abbreviated) ────────────────────────────── -->
    <a
      href="/"
      class="md-hide"
      aria-label="INFONET — go to homepage"
      style="text-decoration: none;"
    >
      <span style="
        font-weight: 900;
        font-size: 28px;
        font-family: 'Raleway', sans-serif;
        letter-spacing: 0.004em;
        color: var(--color-brand);
      ">INFONET</span>
    </a>

    <!-- ── Spacer (desktop — pushes nav items right) ────────────────── -->
    <div style="flex: 1;"></div>

    <!-- ── Desktop nav items
         Plain links: visible at md+ (≥ 960px) — matches legacy `hidden-sm-and-down`
         Dropdowns:  visible at lg+ (≥ 1280px) — matches legacy `hidden-md-and-down`
         The wrapper is md-show; per-item class adjusts further for dropdown items. -->
    <span class="md-show" style="align-items: center; gap: 0;">
      {topNav.map((menu) => (
        <span class={menu.children ? 'lg-only' : ''} style="display: inline-flex; align-items: center;">
          {menu.children ? (
            <details class="nav-dropdown">
              <summary
                class="nav-item-btn"
                aria-label={menu.main}
                style="
                  font-weight: 900;
                  font-size: 18px;
                  font-family: 'Lato', sans-serif;
                  color: var(--color-ink-body);
                  cursor: pointer;
                  min-height: 44px;
                  min-width: 44px;
                  display: inline-flex;
                  align-items: center;
                  justify-content: center;
                  padding: 0 8px;
                  background: transparent;
                  border: none;
                  list-style: none;
                "
              >
                {menu.main}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="margin-left: 2px;">
                  <path d="M7 10l5 5 5-5z"/>
                </svg>
              </summary>
              <ul class="nav-dropdown-menu" style="
                position: absolute;
                background: var(--color-surface);
                border-radius: 4px;
                box-shadow: var(--shadow-elevation-2);
                min-width: 160px;
                list-style: none;
                margin: 0;
                padding: 8px 0;
                z-index: 51;
              ">
                {menu.children.map((child) => {
                  if (child.divider) {
                    return (
                      <li style="margin: 4px 0;">
                        <hr style="border: none; border-top: 1px solid var(--overlay-divider); margin: 0;" />
                      </li>
                    );
                  }
                  if (child.section) {
                    return (
                      <li style="
                        padding: 8px 16px 4px;
                        font-weight: 900;
                        font-size: 12px;
                        color: var(--color-ink-soft);
                        font-family: 'Lato', sans-serif;
                      ">
                        {child.section}
                      </li>
                    );
                  }
                  if (child.link) {
                    return (
                      <li>
                        <a
                          href={child.link}
                          aria-current={pathname === child.link ? 'page' : undefined}
                          style="
                            display: block;
                            padding: 8px 16px;
                            font-size: 12px;
                            font-weight: 700;
                            color: var(--color-ink-87);
                            text-decoration: none;
                            font-family: 'Lato', sans-serif;
                          "
                          class="nav-dropdown-item"
                          {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                        >
                          {child.title}
                        </a>
                      </li>
                    );
                  }
                  return null;
                })}
              </ul>
            </details>
          ) : (
            <a
              href={menu.link}
              aria-label={menu.main}
              aria-current={pathname === menu.link ? 'page' : undefined}
              class="nav-item-btn"
              style="
                font-weight: 900;
                font-size: 18px;
                font-family: 'Lato', sans-serif;
                color: var(--color-ink-body);
                text-decoration: none;
                min-height: 44px;
                min-width: 44px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                padding: 0 8px;
              "
              {...(menu.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {menu.main}
            </a>
          )}
        </span>
      ))}

      <!-- Theme toggle (desktop) — icon-only, sized like the ⋮ summary.
           Moon shown in light mode / sun in dark — CSS-driven via .dark so
           the correct icon renders pre-Alpine (head script already set the
           class). MDI weather-night / white-balance-sunny paths. -->
      <button
        type="button"
        class="theme-toggle"
        x-data
        aria-pressed="false"
        aria-label="Switch to dark theme"
        :aria-pressed="$store.theme.dark"
        :aria-label="$store.theme.dark ? 'Switch to light theme' : 'Switch to dark theme'"
        @click="$store.theme.toggle()"
        style="
          min-height: 44px;
          min-width: 44px;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          cursor: pointer;
          background: transparent;
          border: none;
          padding: 0 4px;
          color: var(--color-ink-87);
        "
      >
        <svg class="theme-toggle__moon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.75,4.09L15.22,6.03L16.13,9.09L13.5,7.28L10.87,9.09L11.78,6.03L9.25,4.09L12.44,4L13.5,1L14.56,4L17.75,4.09M21.25,11L19.61,12.25L20.2,14.23L18.5,13.06L16.8,14.23L17.39,12.25L15.75,11L17.81,10.95L18.5,9L19.19,10.95L21.25,11M18.97,15.95C19.8,15.87 20.69,17.05 20.16,17.8C19.84,18.25 19.5,18.67 19.08,19.07C15.17,23 8.84,23 4.94,19.07C1.03,15.17 1.03,8.83 4.94,4.93C5.34,4.53 5.76,4.17 6.21,3.85C6.96,3.32 8.14,4.21 8.06,5.04C7.79,7.9 8.75,10.87 10.95,13.06C13.14,15.26 16.1,16.22 18.97,15.95Z"/></svg>
        <svg class="theme-toggle__sun" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,2L14.39,5.42C13.65,5.15 12.84,5 12,5C11.16,5 10.35,5.15 9.61,5.42L12,2M3.34,7L7.5,6.65C6.9,7.16 6.36,7.78 5.94,8.5C5.5,9.24 5.25,10 5.11,10.79L3.34,7M3.36,17L5.12,13.23C5.26,14 5.53,14.78 5.95,15.5C6.37,16.24 6.91,16.86 7.5,17.37L3.36,17M20.65,7L18.88,10.79C18.74,10 18.47,9.23 18.05,8.5C17.63,7.78 17.1,7.15 16.5,6.64L20.65,7M20.64,17L16.5,17.36C17.09,16.85 17.62,16.22 18.04,15.5C18.46,14.77 18.73,14 18.87,13.21L20.64,17M12,22L9.59,18.56C10.33,18.83 11.14,19 12,19C12.82,19 13.63,18.83 14.37,18.56L12,22Z"/></svg>
      </button>

      <!-- ⋮ utility dropdown (Search / Translate / Contact) -->
      <span style="display: inline-flex; align-items: center;">
        <details class="nav-dropdown">
          <summary
            aria-label="More options"
            title="More options"
            style="
              min-height: 44px;
              min-width: 44px;
              display: inline-flex;
              align-items: center;
              justify-content: center;
              cursor: pointer;
              background: transparent;
              border: none;
              list-style: none;
              padding: 0 4px;
              color: var(--color-ink-87);
            "
          >
            <!-- MDI dots-vertical -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
            </svg>
          </summary>
          <ul class="nav-dropdown-menu" style="
            position: absolute;
            right: 0;
            background: var(--color-surface);
            border-radius: 4px;
            box-shadow: var(--shadow-elevation-2);
            min-width: 140px;
            list-style: none;
            margin: 0;
            padding: 8px 0;
            z-index: 51;
          ">
            {utilityLinks.map((item, i) => (
              <>
                {i > 0 && i === utilityLinks.length - 1 && (
                  <li style="margin: 4px 0;">
                    <hr style="border: none; border-top: 1px solid var(--overlay-divider); margin: 0;" />
                  </li>
                )}
                <li>
                  <a
                    href={item.link}
                    aria-current={pathname === item.link ? 'page' : undefined}
                    class="nav-dropdown-item"
                    style="
                      display: block;
                      padding: 8px 16px;
                      font-size: 16px;
                      font-weight: 700;
                      color: var(--color-ink-87);
                      text-decoration: none;
                      font-family: 'Lato', sans-serif;
                    "
                  >
                    {item.main}
                  </a>
                </li>
              </>
            ))}
          </ul>
        </details>
      </span>
    </span>

    <!-- ── Mobile/tablet theme toggle (< 960px) — icon + THEME micro-label
         matching MENU/SEARCH; moon in light / sun in dark via .dark CSS. -->
    <button
      type="button"
      class="theme-toggle md-hide"
      x-data
      aria-pressed="false"
      aria-label="Switch to dark theme"
      :aria-pressed="$store.theme.dark"
      :aria-label="$store.theme.dark ? 'Switch to light theme' : 'Switch to dark theme'"
      @click="$store.theme.toggle()"
      style="display:flex;flex-direction:column;align-items:center;justify-content:center;background:transparent;border:none;cursor:pointer;padding:8px;min-width:44px;min-height:44px;color:var(--color-ink-87);"
    >
      <!-- moon (shown in light mode) / sun (shown in dark) — CSS-driven via
           .dark so the correct icon renders pre-Alpine (head script already
           set the class). MDI weather-night / white-balance-sunny paths. -->
      <svg class="theme-toggle__moon" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.75,4.09L15.22,6.03L16.13,9.09L13.5,7.28L10.87,9.09L11.78,6.03L9.25,4.09L12.44,4L13.5,1L14.56,4L17.75,4.09M21.25,11L19.61,12.25L20.2,14.23L18.5,13.06L16.8,14.23L17.39,12.25L15.75,11L17.81,10.95L18.5,9L19.19,10.95L21.25,11M18.97,15.95C19.8,15.87 20.69,17.05 20.16,17.8C19.84,18.25 19.5,18.67 19.08,19.07C15.17,23 8.84,23 4.94,19.07C1.03,15.17 1.03,8.83 4.94,4.93C5.34,4.53 5.76,4.17 6.21,3.85C6.96,3.32 8.14,4.21 8.06,5.04C7.79,7.9 8.75,10.87 10.95,13.06C13.14,15.26 16.1,16.22 18.97,15.95Z"/></svg>
      <svg class="theme-toggle__sun" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,2L14.39,5.42C13.65,5.15 12.84,5 12,5C11.16,5 10.35,5.15 9.61,5.42L12,2M3.34,7L7.5,6.65C6.9,7.16 6.36,7.78 5.94,8.5C5.5,9.24 5.25,10 5.11,10.79L3.34,7M3.36,17L5.12,13.23C5.26,14 5.53,14.78 5.95,15.5C6.37,16.24 6.91,16.86 7.5,17.37L3.36,17M20.65,7L18.88,10.79C18.74,10 18.47,9.23 18.05,8.5C17.63,7.78 17.1,7.15 16.5,6.64L20.65,7M20.64,17L16.5,17.36C17.09,16.85 17.62,16.22 18.04,15.5C18.46,14.77 18.73,14 18.87,13.21L20.64,17M12,22L9.59,18.56C10.33,18.83 11.14,19 12,19C12.82,19 13.63,18.83 14.37,18.56L12,22Z"/></svg>
      <span style="font-size: 10px; font-weight: 900; letter-spacing: 0.04em; text-transform: uppercase;">Theme</span>
    </button>

    <!-- ── Mobile/tablet search icon (< 960px) ─────────────────────── -->
    <a
      href="/search/"
      class="md-hide"
      aria-label="Search"
      style="
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-width: 44px;
        min-height: 44px;
        text-decoration: none;
        color: var(--color-ink-87);
        padding: 8px;
      "
    >
      <!-- MDI magnify -->
      <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
      </svg>
      <span style="font-size: 10px; font-weight: 900; letter-spacing: 0.04em; text-transform: uppercase;">Search</span>
    </a>
  </nav>
</header>

<!-- The hamburger and theme toggles are JS-only (Alpine drawer / theme
     store); without JS the <noscript> fallback nav in AppSidebar provides
     mobile navigation and the theme stays light, so hide the dead controls
     rather than present buttons that do nothing. -->
<noscript>
  <style>
    #nav-hamburger, .theme-toggle { display: none !important; }
  </style>
</noscript>

<!-- Drawer toggling lives on the button itself via Alpine ($store.drawer);
     this script only manages the native <details> dropdowns. -->
<script>
  // Accordion behavior: when one nav <details> dropdown opens, close any other
  // open siblings. Native <details> elements don't do this automatically.
  // Also click-outside-to-close and Escape-to-close.
  const dropdowns = document.querySelectorAll<HTMLDetailsElement>('.nav-dropdown');
  dropdowns.forEach((d) => {
    d.addEventListener('toggle', () => {
      if (d.open) {
        dropdowns.forEach((other) => {
          if (other !== d && other.open) other.open = false;
        });
      }
    });
  });
  // Close any open dropdown when clicking outside the nav header
  document.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof Element)) return;
    if (target.closest('.nav-dropdown')) return;
    dropdowns.forEach((d) => { if (d.open) d.open = false; });
  });
  // Escape closes an open dropdown; if focus was inside it, return focus to
  // its <summary> so keyboard users aren't dropped at the document root.
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    dropdowns.forEach((d) => {
      if (!d.open) return;
      const hadFocus = d.contains(document.activeElement);
      d.open = false;
      if (hadFocus) d.querySelector('summary')?.focus();
    });
  });
</script>

<style>
/* ── Responsive show/hide ─────────────────────────────────────────────── */
/* lg = 960px — matches legacy responsive behaviour: desktop nav (brand
   subtitle + topNav items + ⋮) shows at 1072px viewport, not just 1280px. */

/* Desktop-only elements */
.md-show {
  display: none !important;
}
@media (min-width: 960px) {
  .md-show {
    display: inline-flex !important;
    align-items: center;
  }
  .md-hide {
    display: none !important;
  }
}

/* Dropdown items (About / Resources) hide on md (960-1264px), show on lg+
   Matches legacy Vuetify `hidden-md-and-down` class on dropdown nav items. */
.lg-only {
  display: none !important;
}
@media (min-width: 1264px) {
  .lg-only {
    display: inline-flex !important;
    align-items: center;
  }
}

/* ── Nav item buttons ─────────────────────────────────────────────────── */
.nav-item-btn {
  transition: background-color 0.2s;
  border-radius: 4px;
}
.nav-item-btn:hover {
  background-color: var(--overlay-hover);
}
.nav-item-btn:focus {
  outline: 2px solid var(--color-primary);
  outline-offset: 2px;
}
.nav-item-btn[aria-current="page"] {
  color: var(--color-primary) !important;
}

/* ── Dropdown (native <details>) ────────────────────────────────────── */
.nav-dropdown {
  position: relative;
  display: inline-flex;
  align-items: center;
}
/* Remove default <summary> marker */
.nav-dropdown > summary {
  list-style: none;
}
.nav-dropdown > summary::-webkit-details-marker {
  display: none;
}
.nav-dropdown > summary:focus {
  outline: 2px solid var(--color-primary);
  outline-offset: 2px;
}

/* Dropdown items hover */
.nav-dropdown-item:hover {
  background-color: var(--overlay-hover);
}
.nav-dropdown-item:focus {
  outline: 2px solid var(--color-primary);
  outline-offset: -2px;
}
.nav-dropdown-item[aria-current="page"] {
  background-color: var(--color-primary-tint);
  color: var(--color-primary) !important;
}

/* Dark: the black elevation shadow that separates the white menu from the
   white page in light mode is invisible on a near-black page, so the open
   menu merged with the content behind it. Lift the panel to the soft
   surface and add a hairline border. The inline `background:
   var(--color-surface)` resolves against this scoped re-map, so no
   !important is needed. Dark-only; light is untouched. */
:global(.dark) .nav-dropdown-menu {
  --color-surface: var(--color-surface-soft);
  border: 1px solid var(--color-border);
}

/* ── Hamburger button hover ──────────────────────────────────────────── */
#nav-hamburger:hover {
  background-color: var(--overlay-hover);
  border-radius: 4px;
}
#nav-hamburger:focus {
  outline: 2px solid var(--color-primary);
  outline-offset: 2px;
}

/* ── Theme toggle ────────────────────────────────────────────────────── */
