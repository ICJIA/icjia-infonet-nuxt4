---
// astro/src/components/AppFooter.astro
//
// Port of legacy app/components/content/TheFooter.vue.
// Visual spec:
//   - Background var(--color-brand-footer) (legacy #0d4471)
//   - Centered layout; full-width
//   - ICJIA logo 150×150 (from /icjia-logo.png)
//   - "Privacy | Contact | Translate" links
//   - Copyright © <year> Illinois Criminal Justice Information Authority (links to icjia.illinois.gov)
//
// Social media icons (Facebook, YouTube, Instagram, LinkedIn) were removed 2026-07-15:
// the accounts are managed externally and the URLs couldn't be verified — the Facebook
// link was returning HTTP 400 on every page (a site-wide broken-link hit). Re-add here
// with confirmed URLs if the social media owners provide them.

const currentYear = new Date().getFullYear();
---

<footer
  aria-label="Site footer"
  style="margin:0;padding:0;z-index:1000;"
>
  <div
    class="text-center"
    style="background:var(--color-brand-footer);width:100%;color:var(--color-on-dark);"
  >
    <div style="max-width:960px;margin:0 auto;padding:24px 16px;display:flex;flex-direction:column;align-items:center;gap:16px;">

      <!-- ICJIA Logo -->
      <div style="display:flex;">
        <a
          href="https://icjia.illinois.gov"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Illinois Criminal Justice Information Authority (opens in new window)"
          style="display:inline-block;"
        >
          {/* The logo PNG is 250×175 with ~38px of transparent padding baked in above
              and below the wordmark. object-fit:cover on this short box crops that dead
              space so the footer stays tight and centered now that the social icons
              (which used to fill it) are gone. */}
          <img
            src="/icjia-logo.png"
            alt="Illinois Criminal Justice Information Authority logo"
            width="150"
            height="62"
            style="border:0;display:block;object-fit:cover;object-position:center;aspect-ratio:75 / 31;"
          />
        </a>
      </div>

      <!-- Copyright + nav links -->
      <nav aria-label="Footer" style="font-size:12px;font-weight:400;text-align:center;">
        <strong>
          &copy; {currentYear}
          <a
            href="https://icjia.illinois.gov"
            target="_blank"
            rel="noopener noreferrer"
            style="color:var(--color-on-dark);"
          >Illinois Criminal Justice Information Authority</a>
        </strong>

        <span aria-hidden="true">&nbsp;|&nbsp;</span>
        <strong>
          <a href="/privacy/" style="color:var(--color-on-dark);">Privacy</a>
        </strong>

        <span aria-hidden="true">&nbsp;|&nbsp;</span>
        <a href="/contact/" style="color:var(--color-on-dark);background:none;">Contact</a>

        <span aria-hidden="true">&nbsp;|&nbsp;</span>
        <a
          href="/translate/"
          style="color:var(--color-on-dark);background:none;cursor:pointer;"
        >Translate</a>
      </nav>

    </div>
  </div>
</footer>
