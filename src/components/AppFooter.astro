---

<footer
  aria-label="Site footer"
  style="margin:0;padding:0;z-index:1000;"
>
  <div
    class="text-center pb-4"
    style="background:var(--color-brand-footer);width:100%;color:var(--color-on-dark);"
  >
    <div style="max-width:960px;margin:0 auto;padding:16px 16px 0;">

      <!-- ICJIA Logo -->
      <div style="margin-top:8px;">
        <a
          href="https://icjia.illinois.gov"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Illinois Criminal Justice Information Authority (opens in new window)"
          style="display:inline-block;"
        >
          <img
            src="/icjia-logo.png"
            alt="Illinois Criminal Justice Information Authority logo"
            width="150"
            height="150"
            style="border:0;display:inline;object-fit:contain;aspect-ratio:1/1;"
          />
        </a>
      </div>

      <!-- Social icons -->
      <div style="padding-bottom:24px;margin-top:0;">
        {socialLinks.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.label}
            style="color:var(--color-on-dark);font-size:20px;display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;text-decoration:none;margin:0 2px;"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d={s.d} />
            </svg>
          </a>
        ))}
      </div>

      <!-- Copyright + nav links -->
      <nav aria-label="Footer" style="font-size:12px;font-weight:400;">
        <strong>
          &copy; {currentYear}
          <a
            href="https://icjia.illinois.gov"
            target="_blank"
            rel="noopener noreferrer"
            style="color:var(--color-on-dark);"
          >Illinois Criminal Justice Information Authority</a>
        </strong>

        <span aria-hidden="true">&nbsp;|&nbsp;</span>
        <strong>
          <a href="/privacy/" style="color:var(--color-on-dark);">Privacy</a>
        </strong>

        <span aria-hidden="true">&nbsp;|&nbsp;</span>
        <a href="/contact/" style="color:var(--color-on-dark);background:none;">Contact</a>

        <span aria-hidden="true">&nbsp;|&nbsp;</span>
        <a
          href="/translate/"
          style="color:var(--color-on-dark);background:none;cursor:pointer;"
        >Translate</a>
      </nav>

    </div>
  </div>
</footer>
