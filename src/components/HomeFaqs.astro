---
// astro/src/components/HomeFaqs.astro
//
// Home page "Frequently Asked Questions" section.
// Port of the FAQs section in legacy app/pages/index.vue (DisplayFaqs component).
//
// Pixel-perfect parity with legacy:
//   <DisplayFaqs strapiAgency="general"> in app/pages/index.vue
//   queryContent("/faqs/").where({ agency: "general" })
//                         .sort({ ranking: 1 }).sort({ subcat: 1 }).sort({ cat: 1 })
//
// Filter: agency === "general" (NOT all FAQs)
// Order: ranking asc, then subcat asc, then cat asc
// Limit: NONE — show ALL "general" FAQs (legacy currently has 5)
//
// Section header: h2 "Frequently Asked Questions" + right-aligned "All FAQs »" button.
// Hairline border-top below header row.
import { strapiFetch, assertNoTruncation } from '~/lib/strapi';
import { QUERY_FAQ_LIST } from '~/lib/queries';
import { FaqListResponseSchema } from '~/lib/schemas';
import { renderMarkdown } from '~/lib/markdown';

const raw = await strapiFetch(QUERY_FAQ_LIST);
const parsed = FaqListResponseSchema.parse(raw);
assertNoTruncation('faqs (home)', parsed.faqs.data.length, parsed.faqs.meta?.pagination?.total);
// Sort order matches legacy DisplayFaqs RENDER (not the source).
// Legacy source chained three .sort() calls; Nuxt Content's queryContent
// .sort() replaces prior calls instead of chaining, so only the FINAL sort
// ({ cat: 1 }) applies. With all "general" FAQs having cat: "none", they tie
// on `cat` and fall through to Nuxt Content's default `_path` (slug) order.
// Net result on legacy: alphabetical by slug. Reproducing that here.
const faqs = parsed.faqs.data
  .filter((f) => (f.attributes.agency ?? '').toLowerCase() === 'general')
  .sort((a, b) => a.attributes.slug.localeCompare(b.attributes.slug));
---

{/* data-pagefind-ignore: these accordions duplicate the "general" FAQs that
    /faqs/ already indexes (with per-question deep-link sub-results) — letting
    the home page index them too produced duplicate search hits pointing at
    accordions with no open-on-hash behavior. */}
<section class="home-faqs" data-pagefind-ignore>
  <div class="home-faqs__header">
    <h2 class="home-faqs__heading">Frequently Asked Questions</h2>
    <a href="/faqs/" class="home-faqs__all-btn">
      All FAQs&nbsp;&raquo;
    </a>
  </div>
  <div class="home-faqs__rule"></div>

  <div class="home-faqs__list">
    {faqs.map((f) => {
      const { html } = renderMarkdown(f.attributes.answer);
      return (
        <details class="home-faq-item">
          <summary class="home-faq-item__summary">
            <span>{f.attributes.question ?? '(untitled)'}</span>
            <svg aria-hidden="true" focusable="false" class="home-faq-item__arrow" viewBox="0 0 16 16" width="16" height="16"><path fill="currentColor" d="M2 4l6 7 6-7z"/></svg>
          </summary>
          <div class="home-faq-item__body markdown-body" set:html={html} />
        </details>
      );
    })}
  </div>
</section>

<style>
  .home-faqs {
    /* Internal column padding so the heading + 'All FAQs »' badge don't
       butt up against the News column to its left (or the viewport edge
       on mobile). Outer .home-news-faqs section remains full-bleed. */
    padding: 2rem 2rem 2rem;
  }
  @media (min-width: 960px) {
    .home-faqs {
      padding: 2rem 2rem 2rem 1.5rem;
    }
  }

  .home-faqs__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0;
  }

  .home-faqs__heading {
    border: none;
    margin: 0;
    padding: 0;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .home-faqs__all-btn {
    display: inline-block;
    background: var(--color-brand-deep);
    color: var(--color-on-dark);
    font-weight: 700;
    font-size: 0.75rem;
    padding: 4px 10px;
    text-decoration: none;
    border-radius: 2px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-bottom: 4px;
  }

  .home-faqs__all-btn:hover,
  .home-faqs__all-btn:focus {
    background: var(--color-brand-pressed);
    text-decoration: none;
  }

  .home-faqs__rule {
    border-top: 1px solid var(--color-ink);
    margin-top: 8px;
    margin-bottom: 20px;
  }

  .home-faqs__list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* FAQ accordion item — matches /faqs/ page pattern */
  .home-faq-item {
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }

  .home-faq-item__summary {
    /* Explicit white background so axe can fully resolve contrast of the
       inner ▾ chevron (var(--color-brand), legacy #0d4270) — otherwise axe
       flags "needs review" because nested backgrounds aren't sampled.
       Actual ratio ~12:1. */
    background: var(--color-surface);
    padding: 12px 16px;
    cursor: pointer;
    font-weight: 700;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .home-faq-item__summary::-webkit-details-marker {
    display: none;
  }

  .home-faq-item__summary:focus-visible {
    outline: 2px solid var(--color-brand);
    outline-offset: -2px;
  }

  .home-faq-item__arrow {
    color: var(--color-brand);
    flex-shrink: 0;
    margin-left: 8px;
    display: block;
  }

  .home-faq-item__body {
    padding: 12px 16px 16px;
    border-top: 1px solid var(--color-border);
  }
</style>
