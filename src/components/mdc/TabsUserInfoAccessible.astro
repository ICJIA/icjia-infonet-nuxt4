---
// src/components/mdc/TabsUserInfoAccessible.astro
//
// Ported from v1-final app/components/content/TabsUserInfoAccessible.vue.
// Renders accessible tabs (ARIA tablist + the shared `a11yTabs` Alpine.data
// factory from scripts/alpine-entry.ts) for user info sections.
// The legacy fetched 3 hard-coded slugs from Nuxt Content; this version
// queries Strapi tabs filtered by sectionID at build time.
//
// ids are prefixed with a per-instance uid derived from sectionID so two
// tabs blocks on one CMS page can't emit duplicate ids.
//
// Props:
//   sectionID — filters which tabs to display (e.g., "users")
import { strapiFetch, assertNoTruncation } from '~/lib/strapi';
import { QUERY_TAB_LIST_BY_SECTION } from '~/lib/queries';
import { TabListBySectionResponseSchema } from '~/lib/schemas';
import { renderMarkdown } from '~/lib/markdown';

interface Props {
  sectionID: string;
}

const { sectionID = 'users' } = Astro.props;

const raw = await strapiFetch(QUERY_TAB_LIST_BY_SECTION, { sectionID });
const parsed = TabListBySectionResponseSchema.parse(raw);
assertNoTruncation(`tabs (section ${sectionID})`, parsed.tabs.data.length, parsed.tabs.meta?.pagination?.total);
const tabs = parsed.tabs.data;

const uid = `tui-${sectionID.replace(/[^a-zA-Z0-9_-]/g, '')}`;

// Rendered markdown per tab.
const renderedBodies = tabs.map((tab) => renderMarkdown(tab.attributes.body));
---

{tabs.length === 0 ? (
  <p class="tui-no-tabs">No user info available for section "{sectionID}".</p>
) : (
  <div
    class="tui-wrapper"
    x-data={`a11yTabs(${tabs.length})`}
  >
    <p class="tui-hint">Click tab to view agency info.</p>

    <div class="tui-card">
      <!-- Tab list -->
      <div role="tablist" class="tui-tablist" aria-label="Agency-specific resources">
        {tabs.map((tab, i) => (
          <button
            role="tab"
            class:list={['tui-tab', i === 0 && 'tui-tab--active']}
            id={`${uid}-tab-${i}`}
            aria-controls={`${uid}-panel-${i}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            tabindex={i === 0 ? 0 : -1}
            :class={`{ 'tui-tab--active': activeTab === ${i} }`}
            :aria-selected={`activeTab === ${i}`}
            :tabindex={`activeTab === ${i} ? 0 : -1`}
            data-index={i}
            @click={`setTab(${i})`}
            @keydown={`handleKey($event, ${i})`}
          >
            {tab.attributes.title ?? tab.attributes.agency ?? `Tab ${i + 1}`}
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      <div class="tui-panels">
        {tabs.map((_tab, i) => {
          const { html: bodyHtml } = renderedBodies[i]!;
          return (
            <div
              role="tabpanel"
              class="tui-panel"
              id={`${uid}-panel-${i}`}
              aria-labelledby={`${uid}-tab-${i}`}
              x-show={`activeTab === ${i}`}
              x-cloak={i > 0 ? '' : undefined}
              x-transition:enter="tui-fade-enter"
              x-transition:enter-start="tui-fade-start"
              x-transition:enter-end="tui-fade-end"
              tabindex="0"
            >
              {bodyHtml ? (
                <div class="tui-body markdown-body tab-body" set:html={bodyHtml}></div>
              ) : (
                <p class="tui-empty">No content for this tab.</p>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </div>
)}

<style>
  .tui-wrapper {
    width: 100%;
    margin: 0 0 2rem;
  }

  .tui-hint {
    text-align: center;
    font-size: 12px;
    font-weight: 900;
    color: #525252;
    margin-bottom: 0.75rem;
  }

  .tui-card {
    background: #fff;
    border-radius: 4px;
    box-shadow:
      0 2px 4px -1px rgba(0,0,0,.2),
      0 4px 5px 0 rgba(0,0,0,.14),
      0 1px 10px 0 rgba(0,0,0,.12);
    overflow: hidden;
  }

  /* Tab list */
  .tui-tablist {
    display: flex;
    flex-wrap: wrap;
    background-color: #424242;
    margin: 0;
    padding: 0;
  }

  /* Individual tabs */
  .tui-tab {
    flex: 1 1 auto;
    background-color: transparent;
    border: none;
    color: rgba(255,255,255,0.85);
    font-family: "Lato", sans-serif;
    font-size: 14px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.0892857143em;
    padding: 12px 16px;
    min-height: 48px;
    cursor: pointer;
    position: relative;
    transition: background-color 0.2s;
    white-space: normal;
    word-wrap: break-word;
    overflow-wrap: break-word;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    line-height: 1.5;
    overflow: visible;
  }

  .tui-tab:hover {
    background-color: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.9);
  }

  .tui-tab:focus-visible {
    outline: 2px solid #fff;
    outline-offset: -2px;
    z-index: 1;
  }

  .tui-tab--active {
    color: #fff;
    background-color: #555;
  }

  .tui-tab--active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background-color: #fff;
    animation: tui-slide-in 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes tui-slide-in {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  /* Tab panels */
  .tui-panels {
    background: #fbfbfb;
    min-height: 20vh;
  }

  .tui-panel {
    padding: 16px;
    animation: tui-fade-in 0.2s ease-in;
  }

  @keyframes tui-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Alpine transition helpers */
  .tui-fade-enter { }
  .tui-fade-start { opacity: 0; }
  .tui-fade-end   { opacity: 1; }

  .tui-body {
    font-size: 14px;
  }

  .tui-empty {
    color: #888;
    font-style: italic;
    padding: 1rem;
  }

  .tui-no-tabs {
    color: #888;
    font-style: italic;
  }

  @media (max-width: 600px) {
    .tui-tab {
      font-size: 12px;
      padding: 10px 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tui-tab { transition: none; }
    .tui-tab--active::after { animation: none; }
    .tui-panel { animation: none; }
  }
</style>
