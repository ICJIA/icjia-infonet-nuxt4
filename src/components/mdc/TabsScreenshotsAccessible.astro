---
// src/components/mdc/TabsScreenshotsAccessible.astro
//
// Ported from v1-final app/components/content/TabsScreenshotsAccessible.vue.
// Renders accessible tabs (ARIA tablist pattern + the shared `a11yTabs`
// Alpine.data factory from scripts/alpine-entry.ts) for screenshots sections.
// Fetches tabs filtered by sectionID at build time.
//
// Images resolve through the local cms-image pipeline (lookupCmsImage) when
// the manifest has an entry — same-origin, resized, immutable-cached — and
// fall back to the Strapi origin otherwise. Hotlinking put a third-party
// connection on the LCP path for /screenshots/.
//
// ids are prefixed with a per-instance uid derived from sectionID so two
// tabs blocks on one CMS page can't emit duplicate ids.
//
// Props:
//   sectionID — filters which tabs to display (e.g., "screenshots")
import { strapiFetch, assertNoTruncation } from '~/lib/strapi';
import { QUERY_TAB_LIST_BY_SECTION } from '~/lib/queries';
import { TabListBySectionResponseSchema } from '~/lib/schemas';
import { renderMarkdown, lookupCmsImage } from '~/lib/markdown';

interface Props {
  sectionID: string;
}

const { sectionID = 'screenshots' } = Astro.props;

const STRAPI_BASE = 'https://infonet.icjia-api.cloud';

const raw = await strapiFetch(QUERY_TAB_LIST_BY_SECTION, { sectionID });
const parsed = TabListBySectionResponseSchema.parse(raw);
assertNoTruncation(`tabs (section ${sectionID})`, parsed.tabs.data.length, parsed.tabs.meta?.pagination?.total);
const tabs = parsed.tabs.data;

const uid = `ts-${sectionID.replace(/[^a-zA-Z0-9_-]/g, '')}`;

// Sort images by filename (matches legacy sortImagesByFilename).
type TabImageData = NonNullable<NonNullable<typeof tabs[0]['attributes']['images']>['data']>;
function sortByFilename(images: TabImageData | null | undefined): TabImageData {
  if (!images) return [];
  return [...images].sort((a, b) => {
    const an = a.attributes?.name ?? '';
    const bn = b.attributes?.name ?? '';
    return an < bn ? -1 : an > bn ? 1 : 0;
  });
}

// Pick the smallest Strapi-generated format ≥ thumbWidthPx so we don't ship
// the full-resolution master (saves ~900 KiB on the screenshots gallery).
// Strapi `formats` shape: { thumbnail|small|medium|large: { url, width, height } }
// Fallback: Strapi also exposes every image at /uploads/thumbnail_<basename>
// (the "_thumbnail" convention) — we use it when the formats blob is missing.
type StrapiFormat = { url?: string; width?: number; height?: number };
function thumbnailPrefixUrl(fullUrl: string): string {
  const idx = fullUrl.lastIndexOf('/');
  if (idx < 0) return fullUrl;
  return fullUrl.slice(0, idx + 1) + 'thumbnail_' + fullUrl.slice(idx + 1);
}
function pickThumb(
  formats: unknown,
  fullUrl: string,
  fullW: number | null | undefined,
  fullH: number | null | undefined,
  thumbWidthPx = 500,
): { url: string; width: number; height: number } {
  const fallbackW = fullW ?? 800;
  const fallbackH = fullH ?? 480;
  if (formats && typeof formats === 'object') {
    const order = ['thumbnail', 'small', 'medium', 'large'] as const;
    const byName = formats as Record<string, StrapiFormat>;
    let best: StrapiFormat | null = null;
    for (const key of order) {
      const f = byName[key];
      if (!f || !f.url || !f.width) continue;
      if (f.width >= thumbWidthPx) { best = f; break; }
      best = f;
    }
    if (best && best.url && best.width && best.height) {
      return { url: best.url, width: best.width, height: best.height };
    }
  }
  // Construct Strapi's thumbnail_ URL — preserves aspect ratio, max 245px.
  const scale = Math.min(1, 245 / fallbackW);
  return {
    url: thumbnailPrefixUrl(fullUrl),
    width: Math.round(fallbackW * scale),
    height: Math.round(fallbackH * scale),
  };
}

// Resolve one screenshot to its display + lightbox sources. Local pipeline
// first (same-origin /_cms-img/* variants with srcset); remote Strapi formats
// only when the manifest has no entry for the upload.
type Resolved = {
  src: string;
  srcset?: string;
  sizes?: string;
  width: number;
  height: number;
  fullSrc: string;
};
function resolveScreenshot(img: TabImageData[number]): Resolved | null {
  const rel = img.attributes?.url ?? null;
  if (!rel) return null;
  const remoteFull = rel.startsWith('http') ? rel : `${STRAPI_BASE}${rel}`;
  const localThumb = lookupCmsImage(rel, 640);
  if (localThumb) {
    const localFull = lookupCmsImage(rel, 1280);
    return {
      src: localThumb.src,
      srcset: localThumb.srcset,
      sizes: '(min-width: 600px) 280px, 92vw',
      width: localThumb.width,
      height: localThumb.height,
      fullSrc: localFull?.src ?? remoteFull,
    };
  }
  const t = pickThumb(img.attributes?.formats, remoteFull, img.attributes?.width, img.attributes?.height, 500);
  return {
    src: t.url.startsWith('http') ? t.url : `${STRAPI_BASE}${t.url}`,
    width: t.width,
    height: t.height,
    fullSrc: remoteFull,
  };
}

// Rendered markdown per tab.
const renderedBodies = tabs.map((tab) => renderMarkdown(tab.attributes.body));
---

{tabs.length === 0 ? (
  <p class="ts-no-tabs">No screenshots available for section "{sectionID}".</p>
) : (
  <div
    class="ts-wrapper"
    x-data={`a11yTabs(${tabs.length})`}
  >
    <p class="ts-hint">Click tab to view agency info.</p>

    <div class="ts-card">
      <!-- Tab list -->
      <div role="tablist" class="ts-tablist" aria-label="Agency screenshots">
        {tabs.map((tab, i) => (
          <button
            role="tab"
            class:list={['ts-tab', i === 0 && 'ts-tab--active']}
            id={`${uid}-tab-${i}`}
            aria-controls={`${uid}-panel-${i}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            tabindex={i === 0 ? 0 : -1}
            :class={`{ 'ts-tab--active': activeTab === ${i} }`}
            :aria-selected={`activeTab === ${i}`}
            :tabindex={`activeTab === ${i} ? 0 : -1`}
            data-index={i}
            @click={`setTab(${i})`}
            @keydown={`handleKey($event, ${i})`}
          >
            {tab.attributes.title ?? tab.attributes.agency ?? `Tab ${i + 1}`}
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      <div class="ts-panels">
        {tabs.map((tab, i) => {
          const images = sortByFilename(tab.attributes.images?.data);
          const { html: bodyHtml } = renderedBodies[i]!;
          return (
            <div
              role="tabpanel"
              class="ts-panel"
              id={`${uid}-panel-${i}`}
              aria-labelledby={`${uid}-tab-${i}`}
              x-show={`activeTab === ${i}`}
              x-cloak={i > 0 ? '' : undefined}
              x-transition:enter="ts-fade-enter"
              x-transition:enter-start="ts-fade-start"
              x-transition:enter-end="ts-fade-end"
              tabindex="0"
            >
              <p class="ts-mock-note">Note: All displays contain mock data.</p>

              {bodyHtml && (
                <div class="ts-body markdown-body" set:html={bodyHtml}></div>
              )}

              {images.length > 0 && (
                <div class="ts-gallery">
                  {images.map((img, imgIdx) => {
                    const shot = resolveScreenshot(img);
                    if (!shot) return null;

                    const alt = img.attributes?.alternativeText?.trim()
                      || img.attributes?.caption?.trim()
                      || img.attributes?.name?.replace(/\.\w+$/, '').replace(/_/g, ' ')
                      || 'Screenshot';
                    const caption = img.attributes?.caption?.trim() || null;
                    // First image of the first tab is the visible LCP candidate —
                    // load eagerly + high priority. Everything else lazy.
                    const isLcp = i === 0 && imgIdx === 0;
                    return (
                      <figure class="ts-figure">
                        <button
                          type="button"
                          class="ts-img-link"
                          data-screenshot-src={shot.fullSrc}
                          data-screenshot-alt={alt}
                          data-screenshot-caption={caption ?? ''}
                          aria-label={`View full screenshot: ${alt}`}
                          @click={`$dispatch('ts-lightbox', { uid: '${uid}', src: $el.dataset.screenshotSrc, alt: $el.dataset.screenshotAlt, caption: $el.dataset.screenshotCaption })`}
                        >
                          <img
                            src={shot.src}
                            srcset={shot.srcset}
                            sizes={shot.sizes}
                            alt={alt}
                            width={shot.width}
                            height={shot.height}
                            loading={isLcp ? 'eager' : 'lazy'}
                            fetchpriority={isLcp ? 'high' : 'auto'}
                            decoding="async"
                            class="ts-img"
                          />
                        </button>
                        {caption && <figcaption class="ts-caption">{caption}</figcaption>}
                      </figure>
                    );
                  })}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Modal lightbox, one per component instance (uid-scoped event so two
       instances on a page can't open each other's modal). Alpine-managed:
       x-trap contains Tab focus while open — the old vanilla version set
       aria-modal="true" but never trapped focus, so keyboard users walked
       into background content screen readers said didn't exist. x-trap also
       restores focus to the trigger on close; .noscroll locks body scroll. -->
  <div
    class="ts-modal"
    x-data="{ open: false, src: '', alt: '', caption: '' }"
    x-show="open"
    x-cloak
    x-trap.noscroll="open"
    role="dialog"
    aria-modal="true"
    aria-labelledby={`${uid}-modal-caption`}
    @ts-lightbox.window={`if ($event.detail.uid === '${uid}') { src = $event.detail.src; alt = $event.detail.alt; caption = $event.detail.caption || $event.detail.alt; open = true }`}
    @keydown.escape.window="open = false"
    @click.self="open = false"
  >
    <div class="ts-modal__inner">
      <button type="button" class="ts-modal__close" aria-label="Close screenshot" @click="open = false">&times;</button>
      <img class="ts-modal__img" :src="src" :alt="alt" />
      <div id={`${uid}-modal-caption`} class="ts-modal__caption" x-text="caption"></div>
    </div>
  </div>
)}

<style>
  .ts-wrapper {
    width: 100%;
    margin: 0 0 2rem;
  }

  .ts-hint {
    text-align: center;
    font-size: 12px;
    font-weight: 900;
    color: var(--color-ink-label);
    margin-bottom: 0.75rem;
  }

  .ts-card {
    background: var(--color-surface);
    border-radius: 4px;
    box-shadow: var(--shadow-elevation-4); /* (legacy .2/.14/.12 shorthand) */
    overflow: hidden;
  }

  /* Tab list */
  .ts-tablist {
    display: flex;
    flex-wrap: wrap;
    background-color: var(--color-chrome);
    margin: 0;
    padding: 0;
  }

  /* Individual tabs */
  .ts-tab {
    flex: 1 1 auto;
    background-color: transparent;
    border: none;
    color: var(--color-on-dark-soft);
    font-family: "Lato", sans-serif;
    font-size: 14px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.0892857143em;
    padding: 12px 16px;
    min-height: 48px;
    cursor: pointer;
    position: relative;
    transition: background-color 0.2s;
    white-space: normal;
    word-wrap: break-word;
    overflow-wrap: break-word;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    line-height: 1.5;
    overflow: visible;
  }

  .ts-tab:hover {
    background-color: var(--color-on-dark-hover-bg);
    color: var(--color-on-dark-strong);
  }

  .ts-tab:focus-visible {
    outline: 2px solid var(--color-on-dark);
    outline-offset: -2px;
    z-index: 1;
  }

  .ts-tab--active {
    color: var(--color-on-dark);
    background-color: var(--color-chrome-active);
  }

  .ts-tab--active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background-color: var(--color-on-dark);
  }

  /* Tab panels */
  .ts-panels {
    background: var(--color-surface-faint);
    min-height: 20vh;
  }

  .ts-panel {
    padding: 16px;
  }

  /* Alpine transition helpers */
  .ts-fade-enter { }
  .ts-fade-start { opacity: 0; }
  .ts-fade-end   { opacity: 1; }

  .ts-mock-note {
    text-align: center;
    margin: 2rem 0 1.25rem;
    font-weight: 700;
    color: var(--color-note);
    text-transform: uppercase;
    font-size: 0.85rem;
  }

  .ts-body {
    padding: 1.25rem;
    font-size: 0.9375rem;
  }

  /* Image gallery — responsive thumbnail grid matching legacy layout.
     auto-fill with min ~245px lets 4 cols fit at wide viewports (1280px+),
     3 cols at mid (~900-1280px), 2 cols on tablet (~600-900px), 1 mobile. */
  .ts-gallery {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(245px, 1fr));
    gap: 2rem 1.5rem;
  }

  .ts-figure {
    margin: 0;
    text-align: center;
  }

  .ts-img-link {
    display: block;
    width: 100%;
    padding: 0;
    background: transparent;
    border: none;
    cursor: zoom-in;
  }

  .ts-img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-border-mid);
    border-radius: 2px;
    transition: opacity 0.15s;
  }
  .ts-img-link:hover .ts-img,
  .ts-img-link:focus-visible .ts-img {
    opacity: 0.85;
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }

  .ts-caption {
    font-size: 12px;
    font-weight: 700;
    text-align: center;
    padding: 0.5rem 0.25rem 0;
    color: var(--color-ink-body);
  }

  /* Modal (lightbox) — matches legacy: white modal box on semi-dim backdrop.
     Visibility is Alpine-driven (x-show + x-cloak), so the base display must
     be flex — x-show toggles inline display:none on top of it. */
  .ts-modal {
    position: fixed;
    inset: 0;
    background: var(--overlay-backdrop-modal);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    padding: 2rem;
  }
  .ts-modal__inner {
    position: relative;
    background: var(--color-surface);
    border-radius: 4px;
    box-shadow: 0 8px 32px var(--overlay-shadow-modal); /* (legacy rgba(0,0,0,0.3)) */
    max-width: 1100px;
    width: 100%;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .ts-modal__img {
    width: 100%;
    height: auto;
    max-height: 85vh;
    object-fit: contain;
    display: block;
    background: var(--color-surface);
  }
  .ts-modal__caption {
    color: var(--color-on-dark);
    margin-top: 0.75rem;
    font-size: 14px;
    font-weight: 700;
    text-align: center;
    /* Caption sits in the modal backdrop area below the white box (per legacy) */
    position: absolute;
    bottom: -2rem;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
  }
  .ts-modal__close {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: var(--overlay-scrim);
    border: none;
    color: var(--color-on-dark);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }
  .ts-modal__close:hover,
  .ts-modal__close:focus-visible {
    background: var(--overlay-scrim-deep);
  }
  @media (prefers-reduced-motion: reduce) {
    .ts-img { transition: none; }
  }

  .ts-no-tabs {
    color: var(--color-ink-faint);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .ts-tab {
      font-size: 12px;
      padding: 10px 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ts-tab { transition: none; }
  }
</style>
