---
// astro/src/components/SimpleCard.astro
//
// Minimal placeholder card for Phase 4 listing pages.
// imageUrl prop is accepted but intentionally not rendered —
// Phase 5a wires CmsImage when the image manifest is populated.
//
// Props:
//   title    (required) — card heading
//   href               — makes the card a link
//   date?              — ISO 8601 string; rendered via formatDate('short')
//   summary?           — short body text
//   imageUrl?          — forward-looking prop, ignored until Phase 5a

import { formatDate } from '~/lib/dates';

interface Props {
  title: string;
  href?: string;
  date?: string | null;
  summary?: string | null;
  imageUrl?: string | null;
}

const { title, href, date, summary } = Astro.props;
const displayDate = date ? formatDate(date, 'short') : null;
---

<a
  href={href ?? '#'}
  style="display:block;text-decoration:none;color:inherit;"
>
  {/* onmouseover hover shadow color: var(--shadow-color-soft) (legacy rgba(0,0,0,0.12) — shadow stays black in dark; resolved phase-2 hazard) */}
  <article
    style="
      border: 1px solid var(--color-border);
      border-radius: 4px;
      padding: 16px 20px;
      margin-bottom: 16px;
      background: var(--color-surface-faint);
      transition: box-shadow 0.2s ease;
    "
    onmouseover="this.style.boxShadow='0 4px 12px var(--shadow-color-soft)'"
    onmouseout="this.style.boxShadow='none'"
  >
    {displayDate && (
      <time
        datetime={date ?? ''}
        style="font-size: 0.75rem; font-weight: 700; color: var(--color-ink-soft); text-transform: uppercase; display: block; margin-bottom: 6px;"
      >
        {displayDate}
      </time>
    )}
    <h2 style="margin: 0 0 8px; font-size: 1rem; font-weight: 700; color: var(--color-brand);">
      {title}
    </h2>
    {summary && (
      <p style="margin: 0; font-size: 0.875rem; color: var(--color-ink-mid); line-height: 1.5;">
        {summary}
      </p>
    )}
  </article>
</a>
