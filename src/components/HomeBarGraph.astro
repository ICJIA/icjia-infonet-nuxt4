---
// astro/src/components/HomeBarGraph.astro
//
// Port of legacy app/components/content/HomeBarGraph.vue.
// Bar chart: "Domestic and Sexual Violence Victims Who Received Services
// in Illinois, 2018-2024". Chart.js renders into a <canvas>. An
// accessible sr-only data table is provided for screen readers.
//
// Structure (matches legacy):
//   h2  — chart title (font-size 18px, border none)
//   h3  — "Source: InfoNet System" (font-size 12px, border none) — BETWEEN title and chart
//   canvas — Chart.js bar chart (role="img" + aria-label)
//   sr-only table — visually hidden, screen-reader accessible only (NOT a <details>)
//   "More about InfoNet »" — text link below chart
//
// Dataset ported verbatim from legacy HomeBarGraph.vue:
//   2018: 70,133 | 2019: 72,905 | 2020: 60,717 | 2021: 61,857
//   2022: 61,259 | 2023: 63,211 | 2024: 63,557
---

<div class="home-bar-graph">
  <h2 class="home-bar-graph__title">
    Domestic and Sexual Violence Victims Who Received Services in Illinois, 2018-2024
  </h2>
  <h3 class="home-bar-graph__source">Source: InfoNet System</h3>

  <div class="home-bar-graph__canvas-wrap">
    <canvas
      id="home-bar-graph-canvas"
      role="img"
      aria-label="Bar chart showing domestic and sexual violence victims who received services in Illinois from 2018 to 2024"
      width="600"
      height="400"
      aria-hidden="true"
    ></canvas>
  </div>

  <!-- Screen reader accessible data table (visually hidden — NOT collapsible) -->
  <table class="sr-only-table">
    <caption>Domestic and Sexual Violence Victims Who Received Services, 2018-2024</caption>
    <thead>
      <tr>
        <th scope="col">Year</th>
        <th scope="col">Victims who received services</th>
      </tr>
    </thead>
    <tbody>
      <tr><td>2018</td><td>70,133</td></tr>
      <tr><td>2019</td><td>72,905</td></tr>
      <tr><td>2020</td><td>60,717</td></tr>
      <tr><td>2021</td><td>61,857</td></tr>
      <tr><td>2022</td><td>61,259</td></tr>
      <tr><td>2023</td><td>63,211</td></tr>
      <tr><td>2024</td><td>63,557</td></tr>
    </tbody>
  </table>

  <div class="home-bar-graph__more">
    <a href="/about/" class="home-bar-graph__more-link">More about InfoNet&nbsp;&raquo;</a>
  </div>
</div>

<script>
  import { Chart } from 'chart.js/auto';

  const canvas = document.getElementById('home-bar-graph-canvas');
  if (canvas instanceof HTMLCanvasElement) {
    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    new Chart(canvas, {
      type: 'bar',
      data: {
        labels: ['2018', '2019', '2020', '2021', '2022', '2023', '2024'],
        datasets: [
          {
            label: 'Victims who received services',
            backgroundColor: '#0D4471',
            data: [70133, 72905, 60717, 61857, 61259, 63211, 63557],
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: prefersReducedMotion ? false : { duration: 800 },
        plugins: {
          legend: { display: false },
          title: { display: false },
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: (value) =>
                typeof value === 'number'
                  ? value.toLocaleString()
                  : value,
            },
          },
        },
      },
    });
  }
</script>

<style>
  .home-bar-graph {
    background: #fff;
    border: 1px solid #eee;
    box-shadow: 0 3px 1px -2px rgba(0,0,0,0.2), 0 2px 2px 0 rgba(0,0,0,0.14), 0 1px 5px 0 rgba(0,0,0,0.12);
    padding: 32px;             /* match legacy 32px (was 2rem = 32px at 16px root) */
    text-align: center;
    margin: 0;
  }

  .home-bar-graph__title {
    font-size: 18px;
    border: none;
    margin: 0 0 4px;
    padding: 0;
    line-height: 1.3;
  }

  .home-bar-graph__source {
    font-size: 12px;
    border: none;
    margin: 0 0 12px;
    padding: 0;
    color: #444;
    font-weight: 400;
  }

  .home-bar-graph__canvas-wrap {
    min-height: 25vh;
    position: relative;
    padding-bottom: 40px;
  }

  /* Visually hidden — screen-reader only, NOT collapsible */
  .sr-only-table {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .home-bar-graph__more {
    margin-top: 12px;
    text-align: center;
  }

  .home-bar-graph__more-link {
    font-weight: 700;
    color: #000;
    text-decoration: none;
    font-size: 0.875rem;
  }

  .home-bar-graph__more-link:hover,
  .home-bar-graph__more-link:focus {
    text-decoration: underline;
  }
</style>
