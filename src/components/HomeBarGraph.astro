---
// astro/src/components/HomeBarGraph.astro
//
// Port of legacy app/components/content/HomeBarGraph.vue.
// Bar chart: "Domestic and Sexual Violence Victims Who Received Services
// in Illinois, 2018-2024", rendered as a BUILD-TIME SVG. The data is a
// hardcoded constant, so shipping Chart.js (~71 KB gz) to draw seven
// rectangles was pure client cost — the SVG is computed here at build time
// for zero JS. Native <title> elements give hover tooltips; the sr-only
// table below remains the accessible representation (the SVG is
// aria-hidden, which also resolves the old canvas's contradictory
// role="img" + aria-hidden combination).
//
// Structure (matches legacy):
//   h2  — chart title (font-size 18px, border none)
//   h3  — "Source: InfoNet System" (font-size 12px, border none) — BETWEEN title and chart
//   svg — bar chart (aria-hidden; data lives in the sr-only table)
//   sr-only table — visually hidden, screen-reader accessible only (NOT a <details>)
//   "More about InfoNet »" — text link below chart
//
// Dataset ported verbatim from legacy HomeBarGraph.vue:
//   2018: 70,133 | 2019: 72,905 | 2020: 60,717 | 2021: 61,857
//   2022: 61,259 | 2023: 63,211 | 2024: 63,557

const data = [
  { year: '2018', value: 70133 },
  { year: '2019', value: 72905 },
  { year: '2020', value: 60717 },
  { year: '2021', value: 61857 },
  { year: '2022', value: 61259 },
  { year: '2023', value: 63211 },
  { year: '2024', value: 63557 },
];

// Chart geometry — mirrors the Chart.js defaults the canvas version used:
// y axis from 0 to a "nice" 80,000 max in 10,000 steps, light gridlines,
// gray 11px tick labels, var(--color-brand-footer) (legacy #0D4471) bars with a gap on each side.
const W = 600;
const H = 332;
const M = { top: 10, right: 10, bottom: 28, left: 58 };
const plotW = W - M.left - M.right;
const plotH = H - M.top - M.bottom;
const yMax = 80000;
const yStep = 10000;
const yTicks = Array.from({ length: yMax / yStep + 1 }, (_, i) => i * yStep);

const slot = plotW / data.length;
const barW = slot * 0.72;
const bars = data.map((d, i) => ({
  ...d,
  x: M.left + i * slot + (slot - barW) / 2,
  y: M.top + plotH * (1 - d.value / yMax),
  h: plotH * (d.value / yMax),
  cx: M.left + i * slot + slot / 2,
}));
---

<div class="home-bar-graph">
  <h2 class="home-bar-graph__title">
    Domestic and Sexual Violence Victims Who Received Services in Illinois, 2018-2024
  </h2>
  <h3 class="home-bar-graph__source">Source: InfoNet System</h3>

  <div class="home-bar-graph__canvas-wrap">
    <svg
      class="home-bar-graph__svg"
      viewBox={`0 0 ${W} ${H}`}
      aria-hidden="true"
      focusable="false"
    >
      {yTicks.map((tick) => {
        const y = M.top + plotH * (1 - tick / yMax);
        return (
          <>
            <line
              x1={M.left}
              y1={y}
              x2={W - M.right}
              y2={y}
              style={`stroke: var(${tick === 0 ? '--color-border-faint' : '--color-border-soft'})`}
              stroke-width="1"
            />
            <text
              x={M.left - 8}
              y={y + 4}
              text-anchor="end"
              font-size="11"
              style="fill: var(--color-ink-muted)"
            >
              {tick.toLocaleString('en-US')}
            </text>
          </>
        );
      })}
      {bars.map((bar) => (
        <rect x={bar.x} y={bar.y} width={barW} height={bar.h} style="fill: var(--color-brand-footer)">
          <title>{`${bar.year}: ${bar.value.toLocaleString('en-US')} victims who received services`}</title>
        </rect>
      ))}
      {bars.map((bar) => (
        <text
          x={bar.cx}
          y={H - 8}
          text-anchor="middle"
          font-size="11"
          style="fill: var(--color-ink-muted)"
        >
          {bar.year}
        </text>
      ))}
    </svg>
  </div>

  <!-- Screen reader accessible data table (visually hidden — NOT collapsible) -->
  <table class="sr-only-table">
    <caption>Domestic and Sexual Violence Victims Who Received Services, 2018-2024</caption>
    <thead>
      <tr>
        <th scope="col">Year</th>
        <th scope="col">Victims who received services</th>
      </tr>
    </thead>
    <tbody>
      <tr><td>2018</td><td>70,133</td></tr>
      <tr><td>2019</td><td>72,905</td></tr>
      <tr><td>2020</td><td>60,717</td></tr>
      <tr><td>2021</td><td>61,857</td></tr>
      <tr><td>2022</td><td>61,259</td></tr>
      <tr><td>2023</td><td>63,211</td></tr>
      <tr><td>2024</td><td>63,557</td></tr>
    </tbody>
  </table>

  <div class="home-bar-graph__more">
    <a href="/about/" class="home-bar-graph__more-link">More about InfoNet&nbsp;&raquo;</a>
  </div>
</div>

<style>
  .home-bar-graph {
    background: var(--color-surface);
    border: 1px solid var(--color-surface-press); /* (legacy #eee) */
    box-shadow: var(--shadow-elevation-2);
    padding: 32px;             /* match legacy 32px (was 2rem = 32px at 16px root) */
    text-align: center;
    margin: 0;
  }

  .home-bar-graph__title {
    font-size: 18px;
    border: none;
    margin: 0 0 4px;
    padding: 0;
    line-height: 1.3;
  }

  .home-bar-graph__source {
    font-size: 12px;
    border: none;
    margin: 0 0 12px;
    padding: 0;
    color: var(--color-ink-mid);
    font-weight: 400;
  }

  .home-bar-graph__canvas-wrap {
    /* Measured: legacy chart wrapper renders at 491px tall. With 360px
       canvas-wrap Astro was 519px (28px over). Reducing to 332px brings
       the chart wrapper to ~491px to match legacy exactly. */
    height: 332px;
    position: relative;
    padding-bottom: 40px;
  }

  .home-bar-graph__svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Visually hidden — screen-reader only, NOT collapsible.
     `left: -10000px` pushes the table fully off-canvas so its natural
     content width can't expand document.scrollWidth on narrow viewports
     (was causing ~64 px horizontal overflow at <520 px before the fix). */
  .sr-only-table {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  .home-bar-graph__more {
    margin-top: 12px;
    text-align: center;
  }

  .home-bar-graph__more-link {
    font-weight: 700;
    color: var(--color-ink-max);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .home-bar-graph__more-link:hover,
  .home-bar-graph__more-link:focus {
    text-decoration: underline;
  }
</style>
