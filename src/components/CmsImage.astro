---
// astro/src/components/CmsImage.astro
//
// Tier 2 image-pipeline consumer. Looks up the Strapi `/uploads/*` URL in
// src/lib/cms-image-manifest.json (generated by scripts/fetch-cms-images.mjs)
// and emits a responsive <img srcset sizes src width height>.
//
// Fallbacks:
// - manifest file missing (fresh checkout, no `pnpm fetch:cms-images` yet):
//   emits <img src={fullStrapiUrl} ...> so dev builds still render.
// - URL not in manifest (new content added since last fetch): same fallback.
//
// Usage:
//   <CmsImage src="/uploads/foo.jpg" alt="..." sizes="(min-width: 960px) 33vw, 100vw" />
//   <CmsImage src="/uploads/foo.jpg" alt="..." class="my-class" loading="eager" />
import crypto from 'node:crypto';
import { siteConfig } from '~/lib/siteConfig';

interface ManifestEntry {
  originalUrl: string;
  originalWidth: number;
  originalHeight: number;
  sources: Array<{ width: number; src: string }>;
  ext: string;
}

// ESM dynamic import: evaluated once per build (Vite caches the module
// instance), NOT once per <CmsImage> render. Manifest snapshot persists
// across all component renders within a single build.
let manifest: Record<string, ManifestEntry> = {};
try {
  const mod = await import('~/lib/cms-image-manifest.json');
  manifest = (mod.default ?? mod) as Record<string, ManifestEntry>;
} catch {
  manifest = {};
}

interface Props {
  src: string;
  alt: string;
  sizes?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  decoding?: 'async' | 'sync' | 'auto';
  fetchpriority?: 'auto' | 'high' | 'low';
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  sizes = '(max-width: 768px) 100vw, 50vw',
  class: className,
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  width: widthOverride,
  height: heightOverride,
} = Astro.props;

// Canonicalise src: strip API base prefix to get bare /uploads/... path.
const relPath = src.startsWith('http')
  ? src.replace(siteConfig.api.base, '')
  : src;

const hash = crypto.createHash('sha256').update(relPath).digest('hex');
const entry = manifest[hash];

// Fallback: reconstruct full Strapi URL for unmanifested images.
const fallbackSrc = relPath.startsWith('/uploads')
  ? `${siteConfig.api.base}${relPath}`
  : src;

// If manifest hit: build srcset from all sources, use largest src.
let manifestSrc = '';
let manifestSrcset = '';
if (entry && entry.sources.length > 0) {
  const largest = entry.sources[entry.sources.length - 1];
  manifestSrc = largest.src;
  manifestSrcset = entry.sources.map((s) => `${s.src} ${s.width}w`).join(', ');
}
---
{entry ? (
  <img
    src={manifestSrc}
    srcset={manifestSrcset}
    sizes={sizes}
    alt={alt}
    width={widthOverride ?? entry.originalWidth}
    height={heightOverride ?? entry.originalHeight}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    class={className}
  />
) : (
  <img
    src={fallbackSrc}
    alt={alt}
    width={widthOverride}
    height={heightOverride}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    class={className}
  />
)}
