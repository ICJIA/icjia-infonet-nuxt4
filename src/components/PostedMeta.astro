---
// astro/src/components/PostedMeta.astro
//
// Renders "Published: <date> | <author>" metadata line below article titles.
// Ported from IFVCC PostedMeta.astro, adapted for Infonet field names.
//
// Usage:
//   <PostedMeta date={post.attributes.createdAt} author={post.attributes.category} />
import { formatDate } from '~/lib/dates';

interface Props {
  date?: string | null;
  author?: string | null;
}

const { date, author } = Astro.props;
// Short format matches legacy: "Oct 01, 2025" — NOT the long weekday form.
const displayDate = formatDate(date, 'short');
---
{displayDate && (
  <div class="posted-meta">
    {/* Legacy meta order: date first, then category/author */}
    <time class="posted-meta__date" datetime={date ?? undefined}>{displayDate}</time>
    {author?.trim() && <span class="posted-meta__sep"> | </span>}
    {author?.trim() && (
      <span class="posted-meta__author">{author.trim()}</span>
    )}
  </div>
)}

<style>
  .posted-meta {
    font-size: 0.875rem;
    color: #555;
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-weight: 700;
  }
  .posted-meta__author {
    font-weight: 700;
    text-transform: uppercase;
  }
  .posted-meta__sep {
    font-weight: 400;
  }
  .posted-meta__date {
    font-weight: 400;
  }
</style>
