---
// astro/src/components/HomeBoxes.astro
//
// Port of legacy app/components/content/HomeBoxes.vue.
// Static 3-up grid of linked action boxes on the home page.
// Each box links to a /contact pre-filled subject, with icon, heading,
// and description. Pure CSS grid — no client-side JavaScript.
//
// Colors ported verbatim from legacy HomeBoxes.vue:
//   var(--color-brand-deep) (legacy #0D4474)  — Interested in using InfoNet?  → /contact/?subject=InfoNet Information Request
//   var(--color-brand-box-2) (legacy #1c5183) — Request InfoNet Data          → /contact/?subject=InfoNet Data Request
//   var(--color-brand-box-3) (legacy #3a5571) — Request Technical Assistance  → /contact/?subject=InfoNet Technical Assistance Request

interface Box {
  title: string;
  href: string;
  body: string;
  /** Color-token custom-property name, emitted as `background: var(...)`. Token must be defined in src/styles/global.css @theme — a malformed name renders var() invalid and the box background turns transparent behind white text. */
  color: `--color-${string}`;
  /** Inline SVG path data for the icon */
  svgPath: string;
}

// No aria-label on each .home-box anchor: the visible h3 (title) + p (body)
// are the accessible name. Adding aria-label suppresses that text and trips
// axe's label-content-name-mismatch rule when the label doesn't begin with
// the visible string (axe 4.11 reports this on every .home-box).
const boxes: Box[] = [
  {
    title: 'Interested in using InfoNet?',
    href: '/contact/?subject=InfoNet%20Information%20Request',
    body: 'Click to request more information',
    color: '--color-brand-deep',   // box 1 (legacy #0D4474)
    // MDI account-group (3-person icon — exact path from pictogrammers.com)
    svgPath:
      'M12 5.5A3.5 3.5 0 0 1 15.5 9a3.5 3.5 0 0 1-3.5 3.5A3.5 3.5 0 0 1 8.5 9 3.5 3.5 0 0 1 12 5.5M5 8c.56 0 1.08.15 1.53.42-.15 1.43.27 2.85 1.13 3.96C7.16 13.34 6.16 14 5 14a3 3 0 0 1-3-3 3 3 0 0 1 3-3m14 0a3 3 0 0 1 3 3 3 3 0 0 1-3 3c-1.16 0-2.16-.66-2.66-1.62a5.5 5.5 0 0 0 1.13-3.96c.45-.27.97-.42 1.53-.42M5.5 18.25c0-2.07 2.91-3.75 6.5-3.75s6.5 1.68 6.5 3.75V20h-13v-1.75M0 20v-1.5c0-1.39 1.89-2.56 4.45-2.9-.59.68-.95 1.62-.95 2.65V20H0m24 0h-3.5v-1.75c0-1.03-.36-1.97-.95-2.65 2.56.34 4.45 1.51 4.45 2.9V20Z',
  },
  {
    title: 'Request InfoNet Data',
    href: '/contact/?subject=InfoNet%20Data%20Request',
    body: 'Request InfoNet data',
    color: '--color-brand-box-2',  // box 2 (legacy #1c5183)
    // MDI pencil-ruler (exact path from pictogrammers.com)
    svgPath:
      'M3 17.25V21h3.75L17.81 9.93l-3.75-3.75L3 17.25M22.61 18.36l-3 3a1 1 0 0 1-1.41 0L13 16.16l1.41-1.41L17 17.33l1.59-1.58L16 13.17l1.41-1.41 2.59 2.58L21.2 13l-2-2 1.4-1.43c.41-.4 1.05-.4 1.43 0l1.59 1.59c.39.41.39 1.05 0 1.43L20.78 14.83l1.83 1.83a1 1 0 0 1 0 1.41L20.78 19.5l1.83-1.14M22 3a1 1 0 0 0-1-1H10.66l5.46 5.46L22 3M2.06 7.94 9.06 1l1.41 1.41-7 7L2.06 7.94Z',
  },
  {
    title: 'Request Technical Assistance',
    href: '/contact/?subject=InfoNet%20Technical%20Assistance%20Request',
    body: 'For current InfoNet users',
    color: '--color-brand-box-3',  // box 3 (legacy #3a5571)
    // MDI home (house outline — exact path from pictogrammers.com)
    svgPath: 'M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z',
  },
];
---

<section class="home-boxes" aria-labelledby="home-boxes-heading">
  <h2 id="home-boxes-heading" class="sr-only">Quick Links</h2>
  <ul class="home-boxes__grid">
    {boxes.map((box) => (
      <li>
        <a
          href={box.href}
          class="home-box"
          style={`background: var(${box.color})`}
        >
          <div class="home-box__icon-wrap" aria-hidden="true">
            <svg
              class="home-box__icon"
              viewBox="0 0 24 24"
              style="fill: var(--color-on-dark)"
              width="50"
              height="50"
              aria-hidden="true"
              focusable="false"
            >
              <path d={box.svgPath} />
            </svg>
          </div>
          <h3 class="home-box__head">{box.title}</h3>
          <p class="home-box__text">{box.body}</p>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .home-boxes__grid {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 960px) {
    .home-boxes__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .home-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    padding: 20px 8px;
    color: var(--color-on-dark);
    text-decoration: none;
    text-align: center;
    transition: filter 150ms ease;
  }

  .home-box:hover {
    filter: brightness(1.1);
  }

  .home-box:focus-visible {
    outline: 3px solid var(--color-on-dark);
    outline-offset: -4px;
  }

  .home-box__icon-wrap {
    margin-bottom: 12px;
  }

  .home-box__head {
    color: var(--color-on-dark);
    font-weight: 900;
    font-size: 24px;
    margin: 0 0 10px;
    line-height: 1.2;
  }

  .home-box__text {
    font-size: 20px;
    color: var(--color-on-dark);
    margin: 0;
    line-height: 1.4;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
