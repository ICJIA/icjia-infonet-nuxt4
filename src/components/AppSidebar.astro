---
// astro/src/components/AppSidebar.astro
//
// Mobile navigation drawer. Port of legacy TheSidebar.vue.
//
// State pattern: Alpine.store('drawer') — registered in scripts/alpine-entry.ts.
//   - $store.drawer.open drives visibility; the AppNav hamburger toggles the
//     same store and binds its aria-expanded/aria-label to it, so EVERY close
//     path below keeps the button in sync (the old CustomEvent + local x-data
//     pattern let the hamburger's state invert permanently).
//   - body.drawer-open class follows the store via one x-effect (scroll lock).
//   - Focus trap via x-trap.noscroll.inert (@alpinejs/focus).
//   - Escape key closes drawer globally.
//   - Backdrop click closes drawer.
//   - Every nav link click closes the drawer.
//
// No-JS fallback: the drawer (x-cloak) and hamburger are dead without JS and
// the desktop nav is display:none below 960px — so a <noscript> link list
// renders in normal flow for mobile users with JavaScript disabled.
//
// Visual spec matches legacy Vuetify v-navigation-drawer:
//   - Width 280px, slide-in from left
//   - White background, dark text
//   - Items with children: native <details><summary> accordions
//   - Items without children: plain <a>
//   - utilityLinks section below separator (Search / Translate / Contact)

import { sidebarMenu, utilityLinks } from '~/lib/menu';
const pathname = Astro.url.pathname;

// Flat link list for the <noscript> fallback nav: top-level links, every
// child link, then the utility links. Sections/dividers are skipped.
const noscriptLinks = [
  ...sidebarMenu.flatMap((menu) =>
    menu.children
      ? menu.children
          .filter((c) => c.title && c.link)
          .map((c) => ({ title: c.title!, link: c.link!, external: c.external }))
      : menu.link
        ? [{ title: menu.main, link: menu.link, external: menu.external }]
        : [],
  ),
  ...utilityLinks.map((item) => ({ title: item.main, link: item.link, external: undefined })),
];
---

<!-- No-JS mobile navigation (hidden ≥960px where the desktop <details> nav,
     which works without JS, is visible). Renders in normal document flow. -->
<noscript>
  <nav class="noscript-nav" aria-label="Site navigation">
    <ul>
      {noscriptLinks.map((item) => (
        <li>
          <a
            href={item.link}
            {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {item.title}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</noscript>

<aside
  x-data
  x-effect="document.body.classList.toggle('drawer-open', $store.drawer.open)"
  @keydown.escape.window="$store.drawer.close()"
  aria-label="Mobile navigation"
  style="display: contents;"
>
  <!-- Backdrop -->
  <div
    x-show="$store.drawer.open"
    x-cloak
    x-transition:enter="transition-opacity duration-200 ease-out"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition-opacity duration-200 ease-in"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="$store.drawer.close()"
    aria-hidden="true"
    style="
      position: fixed;
      inset: 0;
      background: var(--overlay-backdrop);
      z-index: 199;
    "
  ></div>

  <!-- Drawer panel -->
  <nav
    id="mobile-navigation"
    x-show="$store.drawer.open"
    x-cloak
    x-trap.noscroll.inert="$store.drawer.open"
    x-transition:enter="transition-transform duration-250 ease-out"
    x-transition:enter-start="-translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition-transform duration-200 ease-in"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="-translate-x-full"
    aria-label="Mobile navigation"
    style="
      position: fixed;
      top: 0;
      left: 0;
      width: 280px;
      height: 100%;
      background: var(--color-surface);
      z-index: 200;
      overflow-y: auto;
      box-shadow: 2px 0 8px var(--shadow-color); /* (legacy rgba(0,0,0,0.15) — shadow stays black in dark; resolved phase-2 hazard) */
    "
  >
    <ul style="list-style: none; margin: 0; padding: 0;">
      {sidebarMenu.map((menu) => (
        <li>
          {menu.children ? (
            <details class="sidebar-group">
              <summary
                class="sidebar-link sidebar-link--parent"
                style="font-weight: 900; color: var(--color-ink-87); cursor: pointer;"
              >
                {menu.main}
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                  class="sidebar-chevron"
                  style="margin-left: auto; flex-shrink: 0; transition: transform 0.2s;"
                >
                  <path d="M7 10l5 5 5-5z"/>
                </svg>
              </summary>
              <ul style="list-style: none; margin: 0; padding: 0;">
                {menu.children.map((child) => (
                  <li>
                    {child.section && (
                      <span
                        class="sidebar-section-label"
                        role="heading"
                        aria-level={4}
                        style="display: block; padding: 8px 16px; font-weight: 900; font-size: 0.875rem; color: var(--color-ink-soft);"
                      >
                        {child.section}
                      </span>
                    )}
                    {child.divider && (
                      <hr style="margin: 0; border: none; border-top: 1px solid var(--overlay-divider);" />
                    )}
                    {child.title && child.link && (
                      <a
                        href={child.link}
                        aria-current={pathname === child.link ? 'page' : undefined}
                        @click="$store.drawer.close()"
                        class="sidebar-child-link"
                        style="
                          display: block;
                          padding: 8px 16px 8px 40px;
                          font-weight: 400;
                          font-size: 0.875rem;
                          color: var(--color-ink-soft);
                          text-decoration: none;
                          min-height: 40px;
                          line-height: 1.5;
                        "
                        {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                      >
                        {child.title}
                      </a>
                    )}
                  </li>
                ))}
              </ul>
            </details>
          ) : (
            <a
              href={menu.link}
              aria-current={pathname === menu.link ? 'page' : undefined}
              @click="$store.drawer.close()"
              class="sidebar-link"
              style="
                font-weight: 900;
                color: var(--color-ink-87);
                text-decoration: none;
              "
              {...(menu.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {menu.main}
            </a>
          )}
        </li>
      ))}

      <!-- Separator -->
      <li aria-hidden="true">
        <hr style="margin: 12px 0; border: none; border-top: 1px solid var(--overlay-divider);" />
      </li>

      <!-- Utility links: Search / Translate / Contact -->
      {utilityLinks.map((item) => (
        <li>
          <a
            href={item.link}
            aria-current={pathname === item.link ? 'page' : undefined}
            @click="$store.drawer.close()"
            class="sidebar-link sidebar-link--utility"
            style="
              font-weight: 400;
              color: var(--color-ink-87);
              text-decoration: none;
            "
          >
            {item.main}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
/* No-JS fallback nav — visible only when scripting is off (and hidden at
   ≥960px, where the JS-free desktop <details> nav takes over). */
.noscript-nav {
  background: var(--color-surface-soft);
  border-bottom: 1px solid var(--overlay-divider);
  padding: 8px 16px;
}
.noscript-nav ul {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 4px 16px;
}
.noscript-nav a {
  display: inline-block;
  padding: 6px 0;
  font-family: 'Lato', sans-serif;
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-brand);
}
@media (min-width: 960px) {
  .noscript-nav {
    display: none;
  }
}

/* Shared link base */
.sidebar-link {
  display: flex;
  align-items: center;
  padding: 8px 16px;
  font-family: 'Lato', sans-serif;
  font-size: 0.875rem;
  min-height: 40px;
  line-height: 1.5;
  transition: background-color 0.2s;
}
.sidebar-link:hover {
  background-color: var(--overlay-hover);
}
.sidebar-link:focus {
  outline: 2px solid var(--color-primary);
  outline-offset: -2px;
}
.sidebar-link[aria-current="page"] {
  background-color: var(--color-primary-tint);
  color: var(--color-primary) !important;
}

/* Child links — indented */
.sidebar-child-link:hover {
  background-color: var(--overlay-hover);
}
.sidebar-child-link:focus {
  outline: 2px solid var(--color-primary);
  outline-offset: -2px;
}
.sidebar-child-link[aria-current="page"] {
  background-color: var(--color-primary-tint);
  color: var(--color-primary) !important;
}

/* <details> group — reset browser default marker */
.sidebar-group {
  list-style: none;
}
.sidebar-group > summary {
  list-style: none;
}
.sidebar-group > summary::-webkit-details-marker {
  display: none;
}

/* Rotate chevron when open */
.sidebar-group[open] .sidebar-chevron {
  transform: rotate(180deg);
}
</style>
