# build output
dist/
# generated types
.astro/
# Build-time caches. `.cache/strapi` (CMS data) is cleared at the start of
# every `pnpm build` so deploys render fresh content; `.cache/cms-img` (raw
# image downloads) is reused between runs and persisted across Netlify builds
# by netlify-plugin-cache (see netlify.toml).
.cache/
# Sharp-resampled Strapi images (fetch-cms-images.mjs skips variants already
# on disk; also persisted across Netlify builds by netlify-plugin-cache)
public/_cms-img/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/
.claude/

# Note: public/_cms-img/dap/ is already covered by `public/_cms-img/` above.
# Note: src/data/dap-splash-manifest.json IS committed so the first
# `astro build` pass can resolve the import in
# src/pages/data-and-publications/index.astro.
# fetch-dap-splash.mjs regenerates the manifest between the two build
# passes (same pattern as src/lib/cms-image-manifest.json).
