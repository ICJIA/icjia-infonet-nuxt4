# build output
dist/
# generated types
.astro/
# Strapi build-time cache (built fresh each `pnpm build`)
.cache/
# Sharp-resampled Strapi images (regenerated by `pnpm fetch:cms-images` on every build)
public/_cms-img/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/
.claude/

# Note: public/_cms-img/dap/ is already covered by `public/_cms-img/` above.
# Note: src/data/dap-splash-manifest.json IS committed so the first
# `astro build` pass can resolve the import in
# src/pages/data-and-publications/index.astro.
# fetch-dap-splash.mjs regenerates the manifest between the two build
# passes (same pattern as src/lib/cms-image-manifest.json).
