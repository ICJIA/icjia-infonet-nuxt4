{
  "source": {
    "include": [
      "app",
      "creators",
      "server",
      "nuxt.config.js"
    ],
    "includePattern": ".+\\.(js(doc|x)?|vue)$",
    "excludePattern": "(^|\\/|\\\\)(node_modules|.nuxt|.output|dist)(\\\\|/)"
  },
  "opts": {
    "destination": "./public/documentation/jsdoc",
    "recurse": true,
    "readme": "./README.md",
    "template": "./node_modules/better-docs"
  },
  "plugins": [
    "plugins/markdown",
    "node_modules/jsdoc-vuejs"
  ],
  "templates": {
    "better-docs": {
      "name": "ICJIA InfoNet - API Documentation",
      "title": "ICJIA InfoNet API Documentation",
      "navigation": [
        {
          "label": "Documentation Portal",
          "href": "/documentation/"
        },
        {
          "label": "GitHub",
          "href": "https://github.com/ICJIA/icjia-infonet-nuxt4"
        }
      ]
    }
  }
}