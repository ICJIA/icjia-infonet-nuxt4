{
  "private": true,
  "scripts": {
    "build": "yarn clear:cache && yarn scripts && nuxt build",
    "build:serve": "rm -rf .nuxt && npm run scripts && nuxt build && node .output/server/index.mjs ",
    "dev": "kill-port 8000 && yarn clear:cache && yarn scripts && nuxt dev --port=8000 -o",
    "dev:local": "kill-port 8000 && yarn scripts:local && nuxt dev --port=8000 -o",
    "generate:local": "yarn scripts:local && nuxt generate",
    "generate": "yarn clear:cache && yarn scripts && nuxt generate",
    "generate:serve": "yarn clear:cache && yarn scripts && nuxt generate && serve ./dist",
    "generate:local:serve": "yarn clear:cache && yarn scripts:local && nuxt generate && serve ./dist",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint:js": "eslint --ext \".js,.vue\" --ignore-path .gitignore . --fix",
    "lint": "npm run lint:js",
    "create:meetings": "node ./creators/createMarkdownMeetings.js",
    "create:faqs": "node ./creators/createMarkdownFaqs.js",
    "create:news": "node ./creators/createMarkdownNews.js",
    "create:routes": "node ./creators/createSiteRoutes.mjs",
    "create:pages": "node ./creators/createMarkdownPages.js",
    "create:tabs": "node ./creators/createMarkdownTabs.js",
    "create:publications": "node ./creators/createMarkdownPublications.js",
    "create:biographies": "node ./creators/createBiographies.js",
    "create:searchIndex": "node  ./creators/createSearchIndex.mjs",
    "create:contentDirectory": "node ./creators/createContentDirectory.js",
    "create:hub": "node ./creators/createHubArticles.mjs",
    "create:hubImages": "node ./creators/createHubImages.mjs",
    "create:publistPublications": "node ./creators/createPublistPublications.mjs",
    "create:mergedPublications": "node ./creators/mergeHubAndPublistPublications.mjs",
    "create:local": "yarn clear:cache && node ./creators/createLocalMeta.mjs",
    "create:sitemap": "node ./creators/createSitemap.mjs",
    "create:jsdoc": "node ./creators/generateJsdoc.js",
    "scripts:local": "yarn create:local",
    "scripts": "yarn create:contentDirectory && yarn create:pages &&  yarn create:publistPublications && yarn create:tabs && yarn create:faqs && yarn create:hub && yarn create:hubImages && yarn create:news && yarn create:mergedPublications && yarn create:searchIndex && yarn create:sitemap && yarn create:routes && yarn create:jsdoc",
    "clear:cache": "rm -rf .nuxt .output",
    "prestart": "source $HOME/.nvm/nvm.sh; nvm use",
    "audit:a11y": "node scripts/accessibility-audit.mjs",
    "audit:a11y:report": "node scripts/open-a11y-report.mjs"
  },
