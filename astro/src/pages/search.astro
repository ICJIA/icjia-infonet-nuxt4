---
// astro/src/pages/search.astro
//
// Phase 6 wires Pagefind UI.
// For now: shell with empty mount point. Pagefind index is generated during
// `pnpm build` and the UI is initialised client-side via a script tag.
// Legacy: app/pages/search.vue used Fuse.js against /api/search endpoint —
// replaced by Pagefind for static-site full-text search.
import BaseLayout from '~/layouts/BaseLayout.astro';
---
<BaseLayout title="Search" breadcrumbTitle="Search">
  <h1>Search</h1>
  <!-- Phase 6 wires Pagefind UI: installs @pagefind/default-ui, adds CSS import,
       and inits PagefindUI({ element: '#pagefind-ui' }) in a client script. -->
  <div id="pagefind-ui" style="max-width: 720px; margin-top: 16px;">
    <p style="color: #666; font-size: 0.875rem;">Search functionality coming soon.</p>
  </div>
</BaseLayout>
