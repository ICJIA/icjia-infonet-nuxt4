---
// astro/src/components/HomeBoxes.astro
//
// Port of legacy app/components/content/HomeBoxes.vue.
// Static 3-up grid of linked action boxes on the home page.
// Each box links to a /contact pre-filled subject, with icon, heading,
// and description. Pure CSS grid — no client-side JavaScript.
//
// Colors ported verbatim from legacy HomeBoxes.vue:
//   #0D4474 — Interested in using InfoNet?  → /contact?subject=InfoNet Information Request
//   #1c5183 — Request InfoNet Data          → /contact?subject=InfoNet Data Request
//   #3a5571 — Request Technical Assistance  → /contact?subject=InfoNet Technical Assistance Request

interface Box {
  title: string;
  href: string;
  body: string;
  color: string;
  /** Inline SVG path data for the icon */
  svgPath: string;
  ariaLabel: string;
}

const boxes: Box[] = [
  {
    title: 'Interested in using InfoNet?',
    href: '/contact?subject=InfoNet%20Information%20Request',
    body: 'Click to request more information',
    color: '#0D4474',
    // MDI account-group
    svgPath:
      'M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z',
    ariaLabel: 'Request information about using InfoNet',
  },
  {
    title: 'Request InfoNet Data',
    href: '/contact?subject=InfoNet%20Data%20Request',
    body: 'Request InfoNet data',
    color: '#1c5183',
    // MDI pencil-ruler (approximated with mdi-chart-bar for data context; using table-edit path)
    svgPath:
      'M20.71 7.04c.39-.39.39-1.04 0-1.41l-2.34-2.34c-.37-.39-1.02-.39-1.41 0l-1.84 1.83 3.75 3.75M3 17.25V21h3.75L17.81 9.93l-3.75-3.75L3 17.25z',
    ariaLabel: 'Request InfoNet data',
  },
  {
    title: 'Request Technical Assistance',
    href: '/contact?subject=InfoNet%20Technical%20Assistance%20Request',
    body: 'For current InfoNet users',
    color: '#3a5571',
    // MDI home (legacy icon: mdi-home)
    svgPath: 'M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z',
    ariaLabel: 'Request technical assistance for InfoNet',
  },
];
---

<section class="home-boxes" aria-labelledby="home-boxes-heading">
  <h2 id="home-boxes-heading" class="sr-only">Quick Links</h2>
  <ul class="home-boxes__grid">
    {boxes.map((box) => (
      <li>
        <a
          href={box.href}
          class="home-box"
          style={`background: ${box.color}`}
          aria-label={box.ariaLabel}
        >
          <div class="home-box__icon-wrap" aria-hidden="true">
            <svg
              class="home-box__icon"
              viewBox="0 0 24 24"
              fill="#fff"
              width="50"
              height="50"
              aria-hidden="true"
              focusable="false"
            >
              <path d={box.svgPath} />
            </svg>
          </div>
          <h3 class="home-box__head">{box.title}</h3>
          <p class="home-box__text">{box.body}</p>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .home-boxes__grid {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 960px) {
    .home-boxes__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .home-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    padding: 20px 8px;
    color: #fff;
    text-decoration: none;
    text-align: center;
    transition: filter 150ms ease;
  }

  .home-box:hover {
    filter: brightness(1.1);
  }

  .home-box:focus-visible {
    outline: 3px solid #fff;
    outline-offset: -4px;
  }

  .home-box__icon-wrap {
    margin-bottom: 12px;
  }

  .home-box__head {
    color: #fff;
    font-weight: 900;
    font-size: 24px;
    margin: 0 0 10px;
    line-height: 1.2;
  }

  .home-box__text {
    font-size: 20px;
    color: #fff;
    margin: 0;
    line-height: 1.4;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
